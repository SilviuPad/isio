---
import Base from './Base.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import type { Locale } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  roSlug: string;
  enSlug: string;
  ogImage?: string;
  pageType?: 'home' | 'service' | 'pricing' | 'portfolio' | 'about' | 'contact' | 'default';
  serviceName?: string;
}

const { title, description, locale, roSlug, enSlug, ogImage, pageType, serviceName } = Astro.props;
---
<Base title={title} description={description} locale={locale} roSlug={roSlug} enSlug={enSlug} ogImage={ogImage} pageType={pageType} serviceName={serviceName}>
  <Header locale={locale} roSlug={roSlug} enSlug={enSlug} />
  <main>
    <slot />
  </main>
  <Footer locale={locale} />
</Base>
