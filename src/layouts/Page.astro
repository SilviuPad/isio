---
import Base from './Base.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import type { Locale } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  roSlug: string;
  enSlug: string;
  ogImage?: string;
}

const { title, description, locale, roSlug, enSlug, ogImage } = Astro.props;
---
<Base title={title} description={description} locale={locale} roSlug={roSlug} enSlug={enSlug} ogImage={ogImage}>
  <Header locale={locale} roSlug={roSlug} enSlug={enSlug} />
  <main>
    <slot />
  </main>
  <Footer locale={locale} />
</Base>
