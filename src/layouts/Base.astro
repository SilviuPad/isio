---
import { SEO } from 'astro-seo';
import JsonLd from '../components/seo/JsonLd.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  locale: 'ro' | 'en';
  roSlug: string;
  enSlug: string;
  ogImage?: string;
  pageType?: 'home' | 'service' | 'pricing' | 'portfolio' | 'about' | 'contact' | 'default';
  serviceName?: string;
}

const { title, description = '', locale, roSlug, enSlug, ogImage, pageType = 'default', serviceName } = Astro.props;
const baseUrl = 'https://isio.ro';
const canonicalUrl = locale === 'ro' ? `${baseUrl}${roSlug}` : `${baseUrl}${enSlug}`;
const defaultOgImage = `${baseUrl}/og.png`;
---
<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/sora-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/space-grotesk-latin.woff2" as="font" type="font/woff2" crossorigin />
    <style is:inline>
      @font-face{font-family:'Sora';font-style:normal;font-weight:600 700;font-display:swap;src:url('/fonts/sora-latin.woff2') format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
      @font-face{font-family:'Space Grotesk';font-style:normal;font-weight:500 700;font-display:swap;src:url('/fonts/space-grotesk-latin.woff2') format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
    </style>
    <SEO
      title={title}
      description={description}
      canonical={canonicalUrl}
      languageAlternates={[
        { href: `${baseUrl}${roSlug}`, hrefLang: 'ro' },
        { href: `${baseUrl}${enSlug}`, hrefLang: 'en' },
        { href: `${baseUrl}${roSlug}`, hrefLang: 'x-default' },
      ]}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: ogImage || defaultOgImage,
          url: canonicalUrl,
        },
        optional: {
          locale: locale === 'ro' ? 'ro_RO' : 'en_US',
          siteName: 'ISIO',
          description: description,
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: title,
        description: description,
        image: ogImage || defaultOgImage,
      }}
    />
    <JsonLd locale={locale} pageType={pageType} serviceName={serviceName} title={title} roSlug={roSlug} enSlug={enSlug} />
    {pageType === 'home' && (
      <link rel="preload" href="/images/services/ai-agents.svg" as="image" type="image/svg+xml" />
    )}
  </head>
  <body class="bg-base-950 text-base-100 min-h-screen antialiased">
    <slot />

    <!-- All animations consolidated into single entry point to flatten critical chain -->
    <script>
      async function initAnimations() {
        const [{ default: Lenis }, { gsap }, { ScrollTrigger }] = await Promise.all([
          import('lenis'),
          import('gsap'),
          import('gsap/ScrollTrigger'),
        ]);
        gsap.registerPlugin(ScrollTrigger);

        // === LENIS SMOOTH SCROLL ===
        const lenis = new Lenis({
          duration: 2.8,
          easing: (t) => t === 1 ? 1 : 1 - Math.pow(2, -10 * t),
          lerp: 0.05,
          smoothTouch: false,
        });

        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => lenis.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);

        // === GLOBAL DATA-ANIMATE HANDLER ===
        gsap.utils.toArray<Element>('[data-animate]').forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight) {
            gsap.set(el, { opacity: 1, y: 0, clearProps: 'all' });
          } else {
            gsap.from(el, {
              y: 40,
              opacity: 0,
              duration: 0.8,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 90%',
                once: true,
              },
            });
          }
        });

        // === MAGNETIC BUTTONS ===
        document.querySelectorAll('.magnetic-btn').forEach((btn) => {
          const el = btn as HTMLElement;
          el.addEventListener('mousemove', (e: MouseEvent) => {
            const rect = el.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            gsap.to(el, { x: x * 0.3, y: y * 0.3, duration: 0.3, ease: 'power2.out' });
          });
          el.addEventListener('mouseleave', () => {
            gsap.to(el, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.5)' });
          });
        });

        // === HERO EFFECTS ===
        const hero = document.getElementById('hero-section');
        if (hero) {
          const mouseGlow = document.getElementById('hero-mouse-glow');
          let glowRafId: number | null = null;
          let mouseX = window.innerWidth / 2;
          let mouseY = window.innerHeight / 2;
          let glowX = mouseX;
          let glowY = mouseY;

          function animateGlow() {
            if (!mouseGlow) return;
            glowX += (mouseX - glowX) * 0.06;
            glowY += (mouseY - glowY) * 0.06;
            mouseGlow.style.left = `${glowX}px`;
            mouseGlow.style.top = `${glowY}px`;
            glowRafId = requestAnimationFrame(animateGlow);
          }

          if (mouseGlow) {
            hero.addEventListener('mousemove', (e: MouseEvent) => {
              const rect = hero.getBoundingClientRect();
              mouseX = e.clientX - rect.left;
              mouseY = e.clientY - rect.top;
            });

            let idleTimer: ReturnType<typeof setTimeout>;
            hero.addEventListener('mousemove', () => {
              gsap.to(mouseGlow, { width: 700, height: 700, duration: 0.3, ease: 'power2.out' });
              clearTimeout(idleTimer);
              idleTimer = setTimeout(() => {
                gsap.to(mouseGlow, { width: 500, height: 500, duration: 1.5, ease: 'power2.out' });
              }, 200);
            });

            glowRafId = requestAnimationFrame(animateGlow);
          }

          const orbTweens: gsap.core.Tween[] = [];
          function floatOrb(id: string, xRange: number, yRange: number, duration: number) {
            const el = document.getElementById(id);
            if (!el) return;
            orbTweens.push(
              gsap.to(el, { x: `random(-${xRange}, ${xRange})`, y: `random(-${yRange}, ${yRange})`, duration, ease: 'sine.inOut', repeat: -1, yoyo: true, repeatRefresh: true }),
              gsap.to(el, { scale: 'random(0.8, 1.2)', duration: duration * 1.3, ease: 'sine.inOut', repeat: -1, yoyo: true, repeatRefresh: true })
            );
          }
          floatOrb('hero-orb-1', 80, 60, 6);
          floatOrb('hero-orb-2', 100, 80, 8);
          floatOrb('hero-orb-3', 60, 50, 7);

          const scanline = document.getElementById('hero-scanline');
          const scanTween = scanline
            ? gsap.to(scanline, { top: '110%', duration: 4, ease: 'none', repeat: -1, delay: 2 })
            : null;

          new IntersectionObserver(([entry]) => {
            if (entry.isIntersecting) {
              if (mouseGlow && glowRafId === null) glowRafId = requestAnimationFrame(animateGlow);
              orbTweens.forEach(t => t.play());
              scanTween?.play();
            } else {
              if (glowRafId !== null) { cancelAnimationFrame(glowRafId); glowRafId = null; }
              orbTweens.forEach(t => t.pause());
              scanTween?.pause();
            }
          }).observe(hero);
        }

        // === STATS COUNTERS ===
        document.querySelectorAll('[data-counter]').forEach((counter) => {
          const el = counter as HTMLElement;
          const target = parseFloat(el.dataset.counter || '0');
          const suffix = el.dataset.suffix || '';
          let started = false;

          ScrollTrigger.create({
            trigger: el,
            start: 'top 85%',
            once: true,
            onEnter: () => {
              if (started) return;
              started = true;
              el.textContent = '0' + suffix;
              const duration = 4000;
              const startTime = performance.now();

              function update(currentTime: number) {
                const progress = Math.min((currentTime - startTime) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const current = Math.ceil(target * eased);
                el.textContent = current + suffix;
                if (progress < 1) requestAnimationFrame(update);
              }
              requestAnimationFrame(update);
            },
          });
        });
      }

      // Start loading after DOM is ready but don't block rendering
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAnimations, { once: true });
      } else {
        initAnimations();
      }
    </script>
  </body>
</html>
