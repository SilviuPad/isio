---
interface Props {
  currentLocale: 'ro' | 'en';
  roSlug: string;
  enSlug: string;
}

const { currentLocale, roSlug, enSlug } = Astro.props;
---
<nav aria-label="Language switcher" class="flex items-center gap-1 text-sm">
  <a
    href={roSlug}
    aria-current={currentLocale === 'ro' ? 'page' : undefined}
    lang="ro"
    hreflang="ro"
    class:list={[
      'px-2 py-1 rounded transition-colors',
      currentLocale === 'ro'
        ? 'font-semibold text-white bg-base-700'
        : 'text-base-400 hover:text-white hover:bg-base-800',
    ]}
  >
    RO
  </a>
  <span class="text-base-600" aria-hidden="true">|</span>
  <a
    href={enSlug}
    aria-current={currentLocale === 'en' ? 'page' : undefined}
    lang="en"
    hreflang="en"
    class:list={[
      'px-2 py-1 rounded transition-colors',
      currentLocale === 'en'
        ? 'font-semibold text-white bg-base-700'
        : 'text-base-400 hover:text-white hover:bg-base-800',
    ]}
  >
    EN
  </a>
</nav>
