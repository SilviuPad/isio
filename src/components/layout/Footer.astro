---
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentYear = new Date().getFullYear();

const footerText: Record<Locale, { copyright: string; privacy: string }> = {
  ro: {
    copyright: `\u00A9 ${currentYear} Isio. Toate drepturile rezervate.`,
    privacy: 'Politica de confiden\u021Bialitate',
  },
  en: {
    copyright: `\u00A9 ${currentYear} Isio. All rights reserved.`,
    privacy: 'Privacy Policy',
  },
};

const text = footerText[locale];
---
<footer class="border-t border-navy-100 mt-auto">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-navy-400">
      <p>{text.copyright}</p>
      <p>{text.privacy}</p>
    </div>
  </div>
</footer>
