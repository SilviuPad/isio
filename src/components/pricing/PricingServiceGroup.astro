---
import type { Locale } from '../../i18n/utils';
import { localePath } from '../../i18n/utils';
import PricingCard from './PricingCard.astro';
import { localize } from '../../lib/content';

interface TierData {
  id: string;
  service: string;
  order: number;
  name: { ro: string; en: string };
  priceEur: number;
  pricePrefix: string | null;
  deliveryDays: number;
  revisions: number;
  isRecommended: boolean;
  description: { ro: string; en: string };
  features: Array<{ ro: string; en: string; included: boolean }>;
}

interface Props {
  serviceKey: string;
  serviceName: string;
  tiers: TierData[];
  locale: Locale;
}

const { serviceKey, serviceName, tiers, locale } = Astro.props;

const ctaHref = localePath('contact', locale);
---

<div class="mb-20">
  <h2 class="text-2xl font-bold font-heading text-navy-950 mb-8">{serviceName}</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {tiers.map((tier) => (
      <PricingCard
        name={localize(tier.name, locale)}
        priceEur={tier.priceEur}
        pricePrefix={tier.pricePrefix}
        deliveryDays={tier.deliveryDays}
        revisions={tier.revisions}
        isRecommended={tier.isRecommended}
        description={localize(tier.description, locale)}
        features={tier.features.map((f) => ({ text: localize(f, locale), included: f.included }))}
        locale={locale}
        ctaHref={ctaHref}
      />
    ))}
  </div>
</div>
