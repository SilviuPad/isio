---
import type { Locale } from '../../i18n/utils';
import { localePath } from '../../i18n/utils';
import PricingCard from './PricingCard.astro';
import { localize } from '../../lib/content';

interface TierData {
  id: string;
  service: string;
  order: number;
  name: { ro: string; en: string };
  priceEur: number;
  pricePrefix: string | null;
  deliveryDays: number;
  revisions: number;
  isRecommended: boolean;
  description: { ro: string; en: string };
  features: Array<{ ro: string; en: string; included: boolean }>;
}

interface Props {
  serviceKey: string;
  serviceName: string;
  tiers: TierData[];
  locale: Locale;
}

const { serviceKey, serviceName, tiers, locale } = Astro.props;

const contactPath = localePath('contact', locale);
---

<div class="mb-20" data-animate>
  <h2 class="text-2xl font-bold font-heading text-white mb-8">{serviceName}</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
    {tiers.map((tier) => (
      <PricingCard
        name={localize(tier.name, locale)}
        priceEur={tier.priceEur}
        pricePrefix={tier.pricePrefix}
        deliveryDays={tier.deliveryDays}
        revisions={tier.revisions}
        isRecommended={tier.isRecommended}
        description={localize(tier.description, locale)}
        features={tier.features.map((f) => ({ text: localize(f, locale), included: f.included }))}
        locale={locale}
        ctaHref={`${contactPath}?service=${serviceKey}&package=${encodeURIComponent(localize(tier.name, locale))}`}
      />
    ))}
    <!-- Custom / Enquire card -->
    <div class="glass-card p-8 flex flex-col items-center justify-center text-center border-dashed border-white/10">
      <svg class="w-10 h-10 text-electric-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
      </svg>
      <h3 class="text-xl font-bold font-heading text-white">Custom</h3>
      <p class="text-base-400 text-sm mt-2">
        {locale === 'ro'
          ? 'Ai cerințe specifice? Contactează-ne pentru o ofertă personalizată.'
          : 'Have specific requirements? Contact us for a custom quote.'}
      </p>
      <a
        href={`${contactPath}?service=${serviceKey}`}
        class="btn-outline mt-6 inline-flex items-center gap-2 group text-sm"
      >
        {locale === 'ro' ? 'Cere ofertă' : 'Enquire'}
        <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
        </svg>
      </a>
    </div>
  </div>
</div>
