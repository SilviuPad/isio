---
import type { Locale } from '../../i18n/utils';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const blocks = [
  {
    icon: '<svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" /></svg>',
    title: { ro: 'Dezvoltare Web & Apps', en: 'Web & App Development' },
    items: {
      ro: ['Arhitectură full-stack TypeScript', 'Design responsive mobile-first', 'Optimizare Lighthouse 100/100', 'Deployment Cloudflare & Vercel'],
      en: ['Full-stack TypeScript architecture', 'Mobile-first responsive design', 'Lighthouse 100/100 optimization', 'Cloudflare & Vercel deployment'],
    },
  },
  {
    icon: '<svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>',
    title: { ro: 'SEO & Vizibilitate', en: 'SEO & Visibility' },
    items: {
      ro: ['Audit tehnic complet (140+ verificări)', 'Cercetare cuvinte cheie și competitori', 'Schema.org și date structurate', 'Monitorizare poziții și raportare'],
      en: ['Complete technical audit (140+ checks)', 'Keyword research and competitor analysis', 'Schema.org and structured data', 'Position monitoring and reporting'],
    },
  },
  {
    icon: '<svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>',
    title: { ro: 'Automatizare & AI', en: 'Automation & AI' },
    items: {
      ro: ['Agenți AI autonomi 24/7', 'Integrare cu API-uri existente', 'Dashboard de control și monitorizare', 'Deployment pe VPS sau cloud'],
      en: ['24/7 autonomous AI agents', 'Integration with existing APIs', 'Control dashboard and monitoring', 'VPS or cloud deployment'],
    },
  },
];
---
<section class="py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {blocks.map((block) => (
        <div class="glass-card p-8 group hover:border-electric-500/20 transition-all duration-300" data-animate>
          <div class="text-electric-400 mb-6" set:html={block.icon} />
          <h4 class="text-xl font-semibold font-heading text-white mb-6">{block.title[locale]}</h4>
          <ul class="space-y-3">
            {block.items[locale].map((item) => (
              <li class="flex items-start gap-3 text-sm text-base-300">
                <svg class="w-4 h-4 text-electric-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
