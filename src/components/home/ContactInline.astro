---
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';
interface Props { locale: Locale; }
const { locale } = Astro.props;
---
<section class="py-24 bg-base-900/50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Left: info -->
      <div data-animate>
        <span class="section-tag">{locale === 'ro' ? '[ 07 ] contact' : '[ 07 ] get in touch'}</span>
        <h2 class="mt-4 text-3xl sm:text-4xl font-bold font-heading text-white">
          {locale === 'ro' ? 'Suntem mereu gata să te ajutăm' : 'We are always ready to help you'}
        </h2>
        <p class="mt-4 text-base-400 leading-relaxed">
          {locale === 'ro' ? 'Contactează-ne pentru a discuta proiectul tău. Răspundem în maxim 24 de ore.' : 'Get in touch to discuss your project. We respond within 24 hours.'}
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mt-10">
          <div>
            <h4 class="text-white font-heading font-semibold mb-3">Email</h4>
            <a href="mailto:contact@isio.ro" class="text-base-300 hover:text-electric-400 transition-colors">contact@isio.ro</a>
          </div>
          <div>
            <h4 class="text-white font-heading font-semibold mb-3">{locale === 'ro' ? 'Locație' : 'Location'}</h4>
            <p class="text-base-300">{locale === 'ro' ? 'România — remote mondial' : 'Romania — remote worldwide'}</p>
          </div>
          <div>
            <h4 class="text-white font-heading font-semibold mb-3">Social</h4>
            <div class="flex gap-4">
              <a href="#" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-base-400 hover:text-electric-400 hover:border-electric-400/50 transition-all">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
              <a href="#" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-base-400 hover:text-electric-400 hover:border-electric-400/50 transition-all">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
      <!-- Right: form -->
      <div data-animate>
        <div class="glass-card p-8 lg:p-10">
          <h3 class="text-2xl font-bold font-heading text-white mb-6">{locale === 'ro' ? 'Trimite un mesaj' : 'Get in Touch'}</h3>
          <form class="space-y-5">
            <input type="text" placeholder={locale === 'ro' ? 'Nume complet' : 'Full name'} required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors" />
            <input type="email" placeholder="Email" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors" />
            <input type="text" placeholder={locale === 'ro' ? 'Subiect' : 'Subject'} required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors" />
            <textarea rows={5} placeholder={locale === 'ro' ? 'Scrie mesajul tău...' : 'Write your message...'} required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors resize-none"></textarea>
            <button type="submit" class="btn-outline inline-flex items-center gap-2 group">
              {locale === 'ro' ? 'Trimite mesajul' : 'Send message'}
              <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
