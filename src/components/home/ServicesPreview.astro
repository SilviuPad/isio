---
import ServiceCard from '../ui/ServiceCard.astro';
import { getServices, localize } from '../../lib/content';
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { tag: string; title: string; subtitle: string; viewAll: string }> = {
  ro: {
    tag: '[ 01 ] servicii',
    title: 'Ce servicii oferă Isio?',
    subtitle: 'Soluții complete pentru prezența ta digitală',
    viewAll: 'Vezi toate serviciile',
  },
  en: {
    tag: '[ 01 ] services',
    title: 'What services does Isio offer?',
    subtitle: 'Complete solutions for your digital presence',
    viewAll: 'View all services',
  },
};

const l = labels[locale];

const services = await getServices();

// Map serviceKey to slugMap route key
const serviceKeyToRoute: Record<string, string> = {
  'web-development': 'website',
  'web-apps': 'webApps',
  'seo': 'seo',
  'accessibility': 'accessibility',
  'ai-agents': 'aiAgents',
};
---
<section class="bg-base-950 py-24 relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Split title area: heading left, description + button right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-end mb-16" data-animate>
      <div>
        <span class="section-tag">{l.tag}</span>
        <h2 class="mt-4 text-3xl sm:text-4xl font-bold font-heading text-white animated-heading">
          {l.title}
        </h2>
      </div>
      <div class="lg:text-right">
        <p class="text-base-300 mb-6">{l.subtitle}</p>
        <a
          href={localePath('services', locale)}
          class="inline-flex items-center gap-2 text-electric-400 hover:text-electric-300 font-semibold transition-colors group"
        >
          {l.viewAll}
          <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </a>
      </div>
    </div>

    <!-- style mixed service grid: 2 large cards + 1 split column -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 services-grid">
      {services.slice(0, 2).map((service) => {
        const routeKey = serviceKeyToRoute[service.serviceKey] || service.serviceKey;
        return (
          <ServiceCard
            title={localize(service.title, locale)}
            description={localize(service.description, locale)}
            href={localePath(routeKey, locale)}
            serviceKey={service.serviceKey}
            variant="default"
          />
        );
      })}

      <!-- Third column: two stacked compact cards (inline on tablet) -->
      <div class="flex flex-col md:flex-row md:col-span-2 lg:col-span-1 lg:flex-col gap-6">
        {services.slice(2, 4).map((service) => {
          const routeKey = serviceKeyToRoute[service.serviceKey] || service.serviceKey;
          return (
            <ServiceCard
              title={localize(service.title, locale)}
              href={localePath(routeKey, locale)}
              serviceKey={service.serviceKey}
              variant="compact"
            />
          );
        })}
      </div>
    </div>

    <!-- Fifth service: full-width feature card -->
    {services.length > 4 && (
      <a
        href={localePath(serviceKeyToRoute[services[4].serviceKey] || services[4].serviceKey, locale)}
        class="glass-card mt-6 p-8 group cursor-pointer transition-all duration-300 block overflow-hidden"
        data-animate
      >
        <div class="flex flex-col md:flex-row items-start md:items-center gap-6">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-electric-500/20 to-cyan-400/10 flex items-center justify-center shrink-0">
            <svg class="w-8 h-8 text-electric-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-xl font-semibold font-heading text-white group-hover:text-electric-400 transition-colors">
              {localize(services[4].title, locale)}
            </h3>
            <p class="mt-1 text-base-300 text-sm">{localize(services[4].description, locale)}</p>
          </div>
          <span class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-base-300 group-hover:bg-electric-500 group-hover:border-electric-500 group-hover:text-white transition-all duration-300 shrink-0">
            <svg class="w-4 h-4 -rotate-45 group-hover:rotate-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </div>
      </a>
    )}
  </div>
</section>
