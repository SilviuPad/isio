---
import ServiceCard from '../ui/ServiceCard.astro';
import { getServices, localize } from '../../lib/content';
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { tag: string; title: string; subtitle: string; viewAll: string }> = {
  ro: {
    tag: '[ 01 ] Servicii',
    title: 'Servicii',
    subtitle: 'Soluții complete pentru prezența ta digitală',
    viewAll: 'Vezi toate serviciile',
  },
  en: {
    tag: '[ 01 ] Services',
    title: 'Services',
    subtitle: 'Complete solutions for your digital presence',
    viewAll: 'View all services',
  },
};

const l = labels[locale];

const services = await getServices();

// Map serviceKey to slugMap route key
const serviceKeyToRoute: Record<string, string> = {
  'web-development': 'website',
  'web-apps': 'webApps',
  'seo': 'seo',
  'accessibility': 'accessibility',
  'ai-agents': 'aiAgents',
};
---
<section class="bg-base-950 py-24 relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <span class="section-tag">{l.tag}</span>
      <h2 class="mt-4 text-3xl sm:text-4xl font-bold font-heading text-white">{l.title}</h2>
      <p class="mt-4 text-base-400 text-lg">{l.subtitle}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12 services-grid">
      {services.map((service) => {
        const routeKey = serviceKeyToRoute[service.serviceKey] || service.serviceKey;
        return (
          <ServiceCard
            title={localize(service.title, locale)}
            description={localize(service.description, locale)}
            href={localePath(routeKey, locale)}
          />
        );
      })}
    </div>
    <div class="mt-12 text-center" data-animate>
      <a
        href={localePath('services', locale)}
        class="inline-flex items-center text-electric-400 hover:text-electric-300 font-semibold transition-colors duration-300"
      >
        {l.viewAll}
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Staggered scroll animation for service cards
  const servicesGrid = document.querySelector<HTMLElement>('.services-grid');
  if (servicesGrid) {
    const cards = gsap.utils.toArray<HTMLElement>('.services-grid [data-animate]');
    if (cards.length) {
      gsap.from(cards, {
        y: 40,
        opacity: 0,
        duration: 0.8,
        ease: 'power3.out',
        stagger: 0.1,
        scrollTrigger: {
          trigger: servicesGrid,
          start: 'top 85%',
        },
      });
    }

    // Section header (direct parent's sibling, not inside grid)
    const headerEl = servicesGrid.closest('section')?.querySelector('.text-center[data-animate]');
    if (headerEl) {
      gsap.from(headerEl, {
        y: 40,
        opacity: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: { trigger: headerEl, start: 'top 85%' },
      });
    }

    // "View all" link below grid
    const viewAllEl = servicesGrid.nextElementSibling;
    if (viewAllEl && viewAllEl.hasAttribute('data-animate')) {
      gsap.from(viewAllEl, {
        y: 40,
        opacity: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: { trigger: viewAllEl, start: 'top 85%' },
      });
    }
  }
</script>
