---
import type { Locale } from '../../i18n/utils';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const faqs = [
  {
    q: { ro: 'Ce include un proiect de dezvoltare web cu Isio?', en: 'What does a web development project with Isio include?' },
    a: {
      ro: 'Fiecare proiect de dezvoltare web realizat de Isio include un set complet de livrabile: design responsive adaptat tuturor dispozitivelor, optimizare SEO tehnică pentru indexare rapidă în motoarele de căutare, integrare cu un sistem de gestionare a conținutului (CMS) pentru actualizări ușoare, deployment pe infrastructura Cloudflare pentru viteză și securitate globală, certificat SSL inclus, și 30 de zile de suport tehnic post-lansare. Isio livrează codul sursă complet — proiectul este al tău, fără dependență de agenție. Fiecare website este construit cu arhitectură modernă (Astro, TypeScript) și respectă standardele WCAG 2.1 de accesibilitate din prima linie de cod.',
      en: 'Every web development project delivered by Isio includes a complete set of deliverables: responsive design adapted to all devices, technical SEO optimization for fast search engine indexing, content management system (CMS) integration for easy updates, deployment on Cloudflare infrastructure for global speed and security, included SSL certificate, and 30 days of post-launch technical support. Isio delivers the complete source code — the project is yours, with no agency lock-in. Each website is built with modern architecture (Astro, TypeScript) and follows WCAG 2.1 accessibility standards from the first line of code.',
    },
  },
  {
    q: { ro: 'Cât durează un proiect tipic cu Isio?', en: 'How long does a typical project with Isio take?' },
    a: {
      ro: 'Durata unui proiect cu Isio depinde de complexitate și de tipul soluției. Website-urile de prezentare sunt livrate în 14-45 de zile, aplicațiile web personalizate în 30-60 de zile, iar implementările de agenți AI autonomi în 21-60 de zile. Isio stabilește un timeline exact după apelul de descoperire gratuit, în care analizăm cerințele, prioritățile și bugetul tău. Modelul de lucru solo developer al Isio elimină overhead-ul de coordonare — nu există întârzieri cauzate de echipe mari sau procese birocratice. Comunicarea directă cu dezvoltatorul care scrie codul înseamnă decizii rapide și iterații eficiente pe tot parcursul proiectului.',
      en: 'The duration of a project with Isio depends on complexity and solution type. Presentation websites are delivered in 14-45 days, custom web applications in 30-60 days, and autonomous AI agent implementations in 21-60 days. Isio sets an exact timeline after the free discovery call, where we analyze your requirements, priorities, and budget. Isio operates as a solo developer model that eliminates coordination overhead — there are no delays caused by large teams or bureaucratic processes. Direct communication with the developer writing the code means fast decisions and efficient iterations throughout the entire project.',
    },
  },
  {
    q: { ro: 'Ce diferențiază Isio de alte agenții web?', en: 'What makes Isio different from other web agencies?' },
    a: {
      ro: 'Isio funcționează ca un solo developer cu peste 7 ani de experiență full-stack, ceea ce înseamnă zero overhead și comunicare directă cu persoana care scrie codul. Spre deosebire de agențiile tradiționale cu echipe fragmentate, la Isio vorbești direct cu dezvoltatorul — nu există manageri de proiect intermediari, nu există pierderi în comunicare. Isio oferă prețuri transparente fără costuri ascunse, livrare rapidă (de la concept la producție în zile, nu luni), și specializare în tehnologii moderne precum Astro, TypeScript și Cloudflare. În plus, Isio este printre puținele agenții din România care oferă implementare de agenți AI autonomi pentru automatizarea proceselor de business.',
      en: 'Isio operates as a solo developer with over 7 years of full-stack experience, which means zero overhead and direct communication with the person writing the code. Unlike traditional agencies with fragmented teams, at Isio you speak directly with the developer — there are no intermediary project managers, no communication losses. Isio offers transparent pricing with no hidden costs, fast delivery (from concept to production in days, not months), and specialization in modern technologies like Astro, TypeScript, and Cloudflare. Additionally, Isio is among the few agencies in Romania offering autonomous AI agent implementation for business process automation.',
    },
  },
  {
    q: { ro: 'Isio oferă suport după lansarea proiectului?', en: 'Does Isio offer support after project launch?' },
    a: {
      ro: 'Da, Isio oferă suport tehnic post-lansare inclus în fiecare proiect. Perioada de suport variază între 30 și 90 de zile, în funcție de pachetul ales. În această perioadă, Isio rezolvă buguri, face ajustări minore de conținut și asigură funcționarea optimă a proiectului. După expirarea perioadei incluse, suportul continuu este disponibil la cerere, cu termeni flexibili adaptați nevoilor tale. Isio monitorizează performanța website-ului (Core Web Vitals, uptime) și poate interveni rapid în caz de probleme tehnice. Toate proiectele Isio sunt construite cu cod curat și documentat, ceea ce face mentenanța pe termen lung simplă și predictibilă.',
      en: 'Yes, Isio provides post-launch technical support included with every project. The support period ranges from 30 to 90 days, depending on the chosen plan. During this period, Isio fixes bugs, makes minor content adjustments, and ensures optimal project performance. After the included period expires, ongoing support is available on demand, with flexible terms adapted to your needs. Isio monitors website performance (Core Web Vitals, uptime) and can intervene quickly in case of technical issues. All Isio projects are built with clean, documented code, making long-term maintenance simple and predictable.',
    },
  },
];
---
<section class="py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Left: visual (4 cols) -->
      <div class="lg:col-span-4 hidden lg:block" data-animate>
        <div class="aspect-square rounded-2xl relative overflow-hidden bg-base-900 sticky top-24">
          <img src="/images/services/ai-agents.svg" alt="" class="w-full h-full object-cover rounded-2xl" width="480" height="480" loading="lazy" />
        </div>
      </div>
      <!-- Right: FAQ accordion (8 cols) -->
      <div class="lg:col-span-8">
        <div class="mb-12">
          <span class="section-tag">{locale === 'ro' ? '[ 06 ] întrebări frecvente' : '[ 06 ] faq'}</span>
          <h2 class="mt-4 text-3xl sm:text-4xl font-bold font-heading text-white">
            {locale === 'ro' ? 'Ai întrebări despre colaborarea cu Isio?' : 'Have questions about working with Isio?'}
          </h2>
        </div>
        <div class="space-y-4" id="faq-accordion">
          {faqs.map((faq, i) => (
            <div class="glass-card overflow-hidden faq-item" data-animate>
              <button
                class="w-full text-left px-6 py-5 flex items-center justify-between gap-4 faq-trigger"
                data-faq={i}
                aria-expanded={i === 0 ? 'true' : 'false'}
              >
                <span class="text-white font-semibold font-heading pr-4">{faq.q[locale]}</span>
                <span class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center shrink-0 faq-icon transition-transform duration-300">
                  <svg class="w-4 h-4 text-base-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                </span>
              </button>
              <div class={`faq-content px-6 overflow-hidden transition-all duration-300 ${i === 0 ? 'max-h-96 pb-5' : 'max-h-0'}`}>
                <p class="text-base-300 text-sm leading-relaxed">{faq.a[locale]}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const content = item?.querySelector('.faq-content') as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all
      document.querySelectorAll('.faq-trigger').forEach((b) => {
        b.setAttribute('aria-expanded', 'false');
        const c = b.closest('.faq-item')?.querySelector('.faq-content') as HTMLElement;
        const ic = b.querySelector('.faq-icon') as HTMLElement;
        if (c) { c.style.maxHeight = '0'; c.classList.remove('pb-5'); }
        if (ic) ic.style.transform = 'rotate(0deg)';
      });

      // Toggle clicked
      if (!isOpen && content) {
        btn.setAttribute('aria-expanded', 'true');
        content.style.maxHeight = content.scrollHeight + 'px';
        content.classList.add('pb-5');
        if (icon) icon.style.transform = 'rotate(45deg)';
      }
    });
  });
</script>
