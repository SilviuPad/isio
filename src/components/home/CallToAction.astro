---
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { title: string; subtitle: string; cta: string }> = {
  ro: {
    title: 'Gata să începem?',
    subtitle: 'Discutăm despre proiectul tău și găsim cea mai bună soluție.',
    cta: 'Programează un apel',
  },
  en: {
    title: 'Ready to start?',
    subtitle: 'Let\'s talk about your project and find the best solution.',
    cta: 'Book a call',
  },
};

const l = labels[locale];
---
<section class="bg-gradient-to-r from-electric-600 to-electric-500 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold font-heading text-white">{l.title}</h2>
      <p class="mt-4 text-white/80 text-lg">{l.subtitle}</p>
      <a
        href={localePath('contact', locale)}
        class="mt-8 inline-block bg-white text-electric-600 hover:bg-navy-50 px-8 py-4 rounded-full font-semibold transition-colors text-base"
      >
        {l.cta}
      </a>
    </div>
  </div>
</section>
