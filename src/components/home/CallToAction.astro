---
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { heading: string; cta: string }> = {
  ro: { heading: 'Gata să construim ceva excepțional?', cta: 'Programează un apel' },
  en: { heading: 'Ready to build something exceptional?', cta: 'Book a call' },
};
const l = labels[locale];
---
<section class="relative overflow-hidden">
  <!-- Diagonal corner light -->
  <div class="absolute -top-[400px] -right-[400px] w-[1200px] h-[1200px] rounded-full pointer-events-none" aria-hidden="true" style="background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, rgba(34,211,238,0.05) 30%, transparent 70%); filter: blur(40px);"></div>
  <div class="absolute -bottom-[400px] -left-[400px] w-[1200px] h-[1200px] rounded-full pointer-events-none" aria-hidden="true" style="background: radial-gradient(circle, rgba(59,130,246,0.10) 0%, rgba(34,211,238,0.04) 30%, transparent 70%); filter: blur(40px);"></div>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="border-t border-white/5 pt-16">
      <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-8">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-heading text-white max-w-2xl" data-animate>
          {l.heading}
        </h2>
        <a
          href={localePath('contact', locale)}
          class="btn-glow magnetic-btn text-base inline-flex items-center gap-2 shrink-0 group"
          data-animate
        >
          {l.cta}
          <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </a>
      </div>
      <!-- Large ghost text -->
      <div class="mt-12 overflow-hidden" data-animate>
        <span
          class="text-[6rem] sm:text-[8rem] lg:text-[12rem] font-bold font-heading leading-none tracking-tighter select-none"
          style="-webkit-text-stroke: 1px rgba(255,255,255,0.05); color: transparent;"
        >
          ISIO
        </span>
      </div>
    </div>
  </div>
</section>
