---
import type { Locale } from '../../i18n/utils';
interface Props { locale: Locale; }
const { locale } = Astro.props;

// Tech/tool logos as text badges (no external images needed)
const partners = [
  'Astro', 'React', 'TypeScript', 'Tailwind CSS', 'Node.js', 'PostgreSQL',
  'Sanity CMS', 'Cloudflare', 'Vercel', 'Drizzle ORM', 'GSAP', 'Figma',
];
---
<section class="py-20 border-y border-white/5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mb-12" data-animate>
    <span class="section-tag">{locale === 'ro' ? '[ 09 ] parteneri & tehnologii' : '[ 09 ] partners & technologies'}</span>
    <h2 class="mt-4 text-2xl sm:text-3xl font-bold font-heading text-white">
      {locale === 'ro' ? 'Colaboratorii noștri de încredere în progres și succes' : 'Our trusted collaborators in progress and success'}
    </h2>
  </div>
  <!-- Scrolling carousel -->
  <div class="overflow-hidden">
    <div class="partners-track flex gap-8" id="partners-track">
      {/* First set */}
      {partners.map((name) => (
        <div class="glass-card px-8 py-4 shrink-0 flex items-center justify-center hover:border-white/10 transition-all">
          <span class="text-base-400 font-heading font-semibold text-sm whitespace-nowrap">{name}</span>
        </div>
      ))}
      {/* Duplicate for seamless loop */}
      {partners.map((name) => (
        <div class="glass-card px-8 py-4 shrink-0 flex items-center justify-center hover:border-white/10 transition-all">
          <span class="text-base-400 font-heading font-semibold text-sm whitespace-nowrap">{name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Infinite scroll animation (like Aiero's brand carousel)
  const track = document.getElementById('partners-track');
  if (track) {
    let x = 0;
    const speed = -0.4;
    const totalWidth = track.scrollWidth / 2;

    function animate() {
      x += speed;
      if (x <= -totalWidth) x = 0;
      track.style.transform = `translateX(${x}px)`;
      requestAnimationFrame(animate);
    }
    animate();
  }
</script>
