---
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { projects: string; projectsDesc: string; experience: string; experienceDesc: string; satisfaction: string; satisfactionDesc: string }> = {
  ro: {
    projects: 'Proiecte livrate',
    projectsDesc: 'Proiecte de succes pentru clienți din diverse industrii',
    experience: 'Ani experiență',
    experienceDesc: 'Construim produse web de la marketplace-uri la agenți AI autonomi',
    satisfaction: 'Satisfacție clienți',
    satisfactionDesc: 'Fiecare proiect livrat la timp, cu suport post-lansare inclus',
  },
  en: {
    projects: 'Projects delivered',
    projectsDesc: 'Successful projects for clients across industries',
    experience: 'Years experience',
    experienceDesc: 'Building web products from marketplaces to autonomous AI agents',
    satisfaction: 'Client satisfaction',
    satisfactionDesc: 'Every project delivered on time, with post-launch support included',
  },
};

const l = labels[locale];
---
<section class="bg-base-900/50 py-20 border-y border-white/5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-12 gap-8">
      <!-- Large stat -->
      <div class="col-span-2 lg:col-span-6 glass-card p-10" data-animate>
        <div
          class="text-5xl lg:text-7xl font-bold gradient-text font-heading"
          data-counter="6"
          data-suffix="+"
        >6+</div>
        <span class="text-white font-heading font-semibold text-lg mt-4 block">{l.projects}</span>
        <p class="text-base-300 text-sm mt-2">{l.projectsDesc}</p>
      </div>
      <!-- Smaller stat: experience -->
      <div class="lg:col-span-3 p-8" data-animate>
        <div
          class="text-4xl lg:text-5xl font-bold gradient-text font-heading"
          data-counter="7"
          data-suffix="+"
        >7+</div>
        <span class="text-base-300 text-sm mt-2 block uppercase tracking-wider">{l.experience}</span>
        <p class="text-base-500 text-xs mt-2">{l.experienceDesc}</p>
      </div>
      <!-- Smaller stat: satisfaction -->
      <div class="lg:col-span-3 p-8" data-animate>
        <div
          class="text-4xl lg:text-5xl font-bold gradient-text font-heading"
          data-counter="100"
          data-suffix="%"
        >100%</div>
        <span class="text-base-300 text-sm mt-2 block uppercase tracking-wider">{l.satisfaction}</span>
        <p class="text-base-500 text-xs mt-2">{l.satisfactionDesc}</p>
      </div>
    </div>
  </div>
</section>

