---
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { projects: string; projectsDesc: string; experience: string; satisfaction: string }> = {
  ro: {
    projects: 'Proiecte livrate',
    projectsDesc: 'Proiecte de succes pentru clienți din diverse industrii',
    experience: 'Ani experiență',
    satisfaction: 'Satisfacție clienți',
  },
  en: {
    projects: 'Projects delivered',
    projectsDesc: 'Successful projects for clients across industries',
    experience: 'Years experience',
    satisfaction: 'Client satisfaction',
  },
};

const l = labels[locale];
---
<section class="bg-base-900/50 py-20 border-y border-white/5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-12 gap-8">
      <!-- Large stat -->
      <div class="col-span-2 lg:col-span-6 glass-card p-10" data-animate>
        <div
          class="text-5xl lg:text-7xl font-bold gradient-text font-heading"
          data-counter="50"
          data-suffix="+"
        >0+</div>
        <span class="text-white font-heading font-semibold text-lg mt-4 block">{l.projects}</span>
        <p class="text-base-400 text-sm mt-2">{l.projectsDesc}</p>
      </div>
      <!-- Smaller stat: experience -->
      <div class="lg:col-span-3 glass-card p-8" data-animate>
        <div
          class="text-4xl lg:text-5xl font-bold gradient-text font-heading"
          data-counter="7"
          data-suffix="+"
        >0+</div>
        <span class="text-base-400 text-sm mt-2 block uppercase tracking-wider">{l.experience}</span>
      </div>
      <!-- Smaller stat: satisfaction -->
      <div class="lg:col-span-3 glass-card p-8" data-animate>
        <div
          class="text-4xl lg:text-5xl font-bold gradient-text font-heading"
          data-counter="100"
          data-suffix="%"
        >0%</div>
        <span class="text-base-400 text-sm mt-2 block uppercase tracking-wider">{l.satisfaction}</span>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Aiero-style rAF counter with ease-out cubic
  document.querySelectorAll('[data-counter]').forEach((counter) => {
    const el = counter as HTMLElement;
    const target = parseFloat(el.dataset.counter || '0');
    const suffix = el.dataset.suffix || '';
    let started = false;

    ScrollTrigger.create({
      trigger: el,
      start: 'top 85%',
      once: true,
      onEnter: () => {
        if (started) return;
        started = true;
        const duration = 4000; // 4 seconds

        // Slide in the stat block
        gsap.from(el.closest('[data-animate]') ?? el, {
          y: 40,
          opacity: 0,
          duration: 0.8,
          ease: 'power3.out',
        });

        const startTime = performance.now();

        function update(currentTime: number) {
          const progress = Math.min((currentTime - startTime) / duration, 1);
          // Ease out cubic
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.ceil(target * eased);
          el.textContent = current + suffix;
          if (progress < 1) requestAnimationFrame(update);
        }
        requestAnimationFrame(update);
      },
    });
  });
</script>
