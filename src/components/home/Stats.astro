---
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { projects: string; experience: string; technologies: string; satisfaction: string }> = {
  ro: {
    projects: 'Proiecte livrate',
    experience: 'Ani experiență',
    technologies: 'Tehnologii',
    satisfaction: 'Satisfacție clienți',
  },
  en: {
    projects: 'Projects delivered',
    experience: 'Years experience',
    technologies: 'Technologies',
    satisfaction: 'Client satisfaction',
  },
};

const l = labels[locale];

const stats = [
  { number: '50', suffix: '+', label: l.projects },
  { number: '7',  suffix: '+', label: l.experience },
  { number: '20', suffix: '+', label: l.technologies },
  { number: '100', suffix: '%', label: l.satisfaction },
];
---
<section class="bg-base-900/50 py-20 border-y border-white/5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      {stats.map((stat, i) => (
        <div class="text-center" data-animate data-stat-target={stat.number} data-stat-suffix={stat.suffix}>
          <div class="text-4xl lg:text-5xl font-bold gradient-text font-heading stat-number">
            0{stat.suffix}
          </div>
          <div class="text-base-400 text-sm mt-2 uppercase tracking-wider">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const statItems = document.querySelectorAll<HTMLElement>('[data-stat-target]');

  statItems.forEach((item) => {
    const target = parseInt(item.dataset.statTarget ?? '0', 10);
    const suffix = item.dataset.statSuffix ?? '';
    const numberEl = item.querySelector<HTMLElement>('.stat-number');
    if (!numberEl) return;

    const counter = { val: 0 };

    gsap.from(item, {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: item,
        start: 'top 85%',
        onEnter: () => {
          gsap.to(counter, {
            val: target,
            duration: 1.6,
            ease: 'power2.out',
            onUpdate: () => {
              numberEl.textContent = Math.round(counter.val) + suffix;
            },
          });
        },
        once: true,
      },
    });
  });
</script>
