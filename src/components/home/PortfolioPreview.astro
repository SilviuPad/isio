---
import { getPortfolioItems, localize } from '../../lib/content';
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { tag: string; title: string; viewProject: string; viewAll: string }> = {
  ro: {
    tag: '[ 02 ] portofoliu',
    title: 'Proiecte recente',
    viewProject: 'Vezi proiectul',
    viewAll: 'Vezi portofoliul complet',
  },
  en: {
    tag: '[ 02 ] portfolio',
    title: 'Recent projects',
    viewProject: 'View project',
    viewAll: 'View full portfolio',
  },
};

const l = labels[locale];

const portfolioItems = await getPortfolioItems();
---
<section class="bg-base-950 py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Split title area: heading left, link right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-end mb-16" data-animate>
      <div>
        <span class="section-tag">{l.tag}</span>
        <h2 class="mt-4 text-3xl sm:text-4xl font-bold font-heading text-white">
          {l.title}
        </h2>
      </div>
      <div class="lg:text-right">
        <a
          href={localePath('portfolio', locale)}
          class="inline-flex items-center gap-2 text-electric-400 hover:text-electric-300 font-semibold transition-colors group"
        >
          {l.viewAll}
          <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 portfolio-grid">
      {portfolioItems.map((item) => (
        <div class="glass-card overflow-hidden group" data-animate>
          {item.screenshot ? (
            <img
              src={item.screenshot}
              alt={localize(item.title, locale)}
              class="w-full h-48 object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-300"
            />
          ) : (
            <div class="bg-base-800 h-48 flex items-center justify-center border-b border-white/5">
              <span class="text-base-500 text-sm">Screenshot</span>
            </div>
          )}
          <div class="p-5">
            <h3 class="font-heading font-semibold text-white group-hover:text-electric-400 transition-colors duration-300">
              {localize(item.title, locale)}
            </h3>
            <p class="mt-2 text-base-300 text-sm leading-relaxed">{localize(item.description, locale)}</p>
            {item.techStack && item.techStack.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {item.techStack.map((tech: string) => (
                  <span class="bg-white/5 text-base-300 border border-white/10 text-xs px-2 py-1 rounded-full">
                    {tech}
                  </span>
                ))}
              </div>
            )}
            {item.liveUrl && (
              <a
                href={item.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center text-electric-400 hover:text-electric-300 text-sm font-medium transition-colors duration-300"
              >
                {l.viewProject}
                <svg class="ml-1 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
