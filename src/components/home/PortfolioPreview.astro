---
import { getPortfolioItems, localize } from '../../lib/content';
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { title: string; subtitle: string; viewProject: string; viewAll: string }> = {
  ro: {
    title: 'Portofoliu',
    subtitle: 'Proiecte recente',
    viewProject: 'Vezi proiectul',
    viewAll: 'Vezi tot portofoliul',
  },
  en: {
    title: 'Portfolio',
    subtitle: 'Recent projects',
    viewProject: 'View project',
    viewAll: 'View full portfolio',
  },
};

const l = labels[locale];

const portfolioItems = await getPortfolioItems();
---
<section class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold font-heading text-navy-950">{l.title}</h2>
      <p class="mt-4 text-navy-500 text-lg">{l.subtitle}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
      {portfolioItems.map((item) => (
        <div class="rounded-xl overflow-hidden border border-navy-100 bg-white hover:shadow-lg transition-shadow">
          {item.screenshot ? (
            <img
              src={item.screenshot}
              alt={localize(item.title, locale)}
              class="w-full h-48 object-cover"
            />
          ) : (
            <div class="bg-navy-100 h-48 flex items-center justify-center">
              <span class="text-navy-400 text-sm">Screenshot</span>
            </div>
          )}
          <div class="p-5">
            <h3 class="font-heading font-semibold text-navy-950">{localize(item.title, locale)}</h3>
            <p class="mt-2 text-navy-500 text-sm leading-relaxed">{localize(item.description, locale)}</p>
            {item.techStack && item.techStack.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {item.techStack.map((tech: string) => (
                  <span class="bg-navy-50 text-navy-600 text-xs px-2 py-1 rounded-full">{tech}</span>
                ))}
              </div>
            )}
            {item.liveUrl && (
              <a
                href={item.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center text-electric-500 hover:text-electric-600 text-sm font-medium transition-colors"
              >
                {l.viewProject}
                <svg class="ml-1 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
    <div class="mt-12 text-center">
      <a
        href={localePath('portfolio', locale)}
        class="inline-flex items-center text-electric-500 hover:text-electric-600 font-semibold transition-colors"
      >
        {l.viewAll}
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
