---
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { title: string; titleHighlight: string; subtitle: string; ctaServices: string; ctaContact: string }> = {
  ro: {
    title: 'Construim experiențe digitale',
    titleHighlight: 'excepționale',
    subtitle: 'Agenție web specializată în dezvoltare, SEO, accesibilitate și inteligență artificială.',
    ctaServices: 'Descoperă serviciile',
    ctaContact: 'Programează un apel',
  },
  en: {
    title: 'We build exceptional digital',
    titleHighlight: 'experiences',
    subtitle: 'Web agency specializing in development, SEO, accessibility, and artificial intelligence.',
    ctaServices: 'Explore services',
    ctaContact: 'Book a call',
  },
};

const l = labels[locale];
---
<section class="bg-navy-950 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold font-heading text-white leading-tight">
        {l.title}
        {' '}
        <span class="text-electric-400">{l.titleHighlight}</span>
      </h1>
      <p class="mt-6 text-xl text-navy-300 max-w-2xl mx-auto">
        {l.subtitle}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={localePath('services', locale)}
          class="bg-electric-500 hover:bg-electric-600 text-white px-8 py-4 rounded-full font-semibold transition-colors text-base w-full sm:w-auto text-center"
        >
          {l.ctaServices}
        </a>
        <a
          href={localePath('contact', locale)}
          class="border border-navy-600 text-white hover:bg-navy-800 px-8 py-4 rounded-full font-semibold transition-colors text-base w-full sm:w-auto text-center"
        >
          {l.ctaContact}
        </a>
      </div>
    </div>
  </div>
</section>
