---
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { title: string; titleHighlight: string; subtitle: string; ctaServices: string; ctaContact: string }> = {
  ro: {
    title: 'Construim experiențe digitale',
    titleHighlight: 'excepționale',
    subtitle: 'Agenție web specializată în dezvoltare, SEO, accesibilitate și inteligență artificială.',
    ctaServices: 'Descoperă serviciile',
    ctaContact: 'Programează un apel',
  },
  en: {
    title: 'We build exceptional digital',
    titleHighlight: 'experiences',
    subtitle: 'Web agency specializing in development, SEO, accessibility, and artificial intelligence.',
    ctaServices: 'Explore services',
    ctaContact: 'Book a call',
  },
};

const l = labels[locale];
---
<section id="hero-section" class="bg-base-950 relative overflow-hidden min-h-screen flex flex-col justify-center">
  <!-- Dot mesh background -->
  <div class="absolute inset-0 dot-mesh pointer-events-none" aria-hidden="true"></div>

  <!-- Mouse-following glow orb -->
  <div
    id="hero-mouse-glow"
    class="absolute w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(59,130,246,0.18) 0%, rgba(34,211,238,0.08) 35%, transparent 70%); filter: blur(60px); top: 50%; left: 50%; transform: translate(-50%, -50%);"
    aria-hidden="true"
  ></div>

  <!-- Freely floating orbs -->
  <div
    id="hero-orb-1"
    class="absolute w-[400px] h-[400px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(34,211,238,0.12) 0%, transparent 70%); filter: blur(80px); top: 20%; left: 15%;"
    aria-hidden="true"
  ></div>
  <div
    id="hero-orb-2"
    class="absolute w-[350px] h-[350px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(59,130,246,0.10) 0%, transparent 70%); filter: blur(70px); top: 60%; right: 10%;"
    aria-hidden="true"
  ></div>
  <div
    id="hero-orb-3"
    class="absolute w-[250px] h-[250px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 70%); filter: blur(50px); bottom: 15%; left: 40%;"
    aria-hidden="true"
  ></div>

  <!-- Scan line effect -->
  <div
    id="hero-scanline"
    class="absolute left-0 right-0 h-[1px] pointer-events-none"
    style="background: linear-gradient(90deg, transparent 0%, rgba(59,130,246,0.3) 20%, rgba(34,211,238,0.5) 50%, rgba(59,130,246,0.3) 80%, transparent 100%); top: -10%; opacity: 0.6;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full py-32">
    <!-- Split layout: title left, content right -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-end">
      <!-- Left: Big title (8 cols) -->
      <div class="lg:col-span-8">
        <div id="hero-tag" class="section-tag mb-6" style="opacity: 0;">
          [ web agency ]
        </div>
        <h1
          id="hero-title"
          data-split-text
          class="text-4xl sm:text-5xl lg:text-7xl xl:text-8xl font-bold font-heading text-white leading-[1.1]"
          style="opacity: 1;"
        >
          {l.title}
          <br />
          <span class="gradient-text">{l.titleHighlight}</span>
        </h1>
      </div>

      <!-- Right: Description + CTAs (4 cols) -->
      <div class="lg:col-span-4" id="hero-content" style="opacity: 0;">
        <p class="text-base text-base-300 leading-relaxed">
          {l.subtitle}
        </p>
        <div class="mt-8 flex flex-col sm:flex-row lg:flex-col gap-4">
          <a href={localePath('services', locale)} class="btn-glow magnetic-btn text-base text-center inline-flex items-center justify-center gap-2">
            {l.ctaServices}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </a>
          <a href={localePath('contact', locale)} class="btn-outline magnetic-btn text-base text-center inline-flex items-center justify-center gap-2">
            {l.ctaContact}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Brand banner below (Aiero-style large text) -->
    <div class="mt-16 lg:mt-24 border-t border-white/5 pt-12" id="hero-brand" style="opacity: 0;">
      <div class="flex items-center justify-between gap-8">
        <h2 class="text-[8rem] sm:text-[10rem] lg:text-[14rem] font-bold font-heading leading-none tracking-tighter" style="-webkit-text-stroke: 1px rgba(255,255,255,0.08); color: transparent;">
          Isio
        </h2>
        <p class="text-base-400 text-sm max-w-xs hidden sm:block">
          {locale === 'ro' ? 'Soluții creative pentru afacerea ta' : 'Creative solutions for your business'}
        </p>
      </div>
    </div>
  </div>

  <!-- Animated divider line -->
  <div
    id="hero-divider"
    class="absolute bottom-0 left-0 right-0 h-[1px]"
    style="background: linear-gradient(90deg, transparent, rgba(59,130,246,0.5), rgba(34,211,238,0.5), transparent); transform: scaleX(0);"
  ></div>

  <!-- Scroll indicator -->
  <div id="hero-scroll" class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" style="opacity: 0;">
    <span class="text-base-500 text-xs uppercase tracking-widest font-heading">scroll</span>
    <div class="w-[1px] h-8 bg-gradient-to-b from-base-500 to-transparent"></div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  // === MOUSE-FOLLOWING GLOW ===
  const hero = document.getElementById('hero-section');
  const mouseGlow = document.getElementById('hero-mouse-glow');

  if (hero && mouseGlow) {
    let mouseX = window.innerWidth / 2;
    let mouseY = window.innerHeight / 2;
    let glowX = mouseX;
    let glowY = mouseY;

    hero.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });

    // Smooth follow with lerp — glow trails behind cursor
    function animateGlow() {
      glowX += (mouseX - glowX) * 0.06;
      glowY += (mouseY - glowY) * 0.06;
      mouseGlow.style.left = `${glowX}px`;
      mouseGlow.style.top = `${glowY}px`;
      requestAnimationFrame(animateGlow);
    }
    animateGlow();

    // Pulse glow size on mouse movement
    hero.addEventListener('mousemove', () => {
      gsap.to(mouseGlow, {
        width: 700,
        height: 700,
        duration: 0.3,
        ease: 'power2.out',
      });
    });

    // Shrink when mouse stops
    let idleTimer: ReturnType<typeof setTimeout>;
    hero.addEventListener('mousemove', () => {
      clearTimeout(idleTimer);
      idleTimer = setTimeout(() => {
        gsap.to(mouseGlow, {
          width: 500,
          height: 500,
          duration: 1.5,
          ease: 'power2.out',
        });
      }, 200);
    });
  }

  // === FREELY FLOATING ORBS ===
  // Each orb drifts on its own random path
  function floatOrb(id: string, xRange: number, yRange: number, duration: number) {
    const el = document.getElementById(id);
    if (!el) return;

    gsap.to(el, {
      x: `random(-${xRange}, ${xRange})`,
      y: `random(-${yRange}, ${yRange})`,
      duration: duration,
      ease: 'sine.inOut',
      repeat: -1,
      yoyo: true,
      repeatRefresh: true, // new random values each cycle
    });

    // Also slowly scale/pulse
    gsap.to(el, {
      scale: 'random(0.8, 1.2)',
      duration: duration * 1.3,
      ease: 'sine.inOut',
      repeat: -1,
      yoyo: true,
      repeatRefresh: true,
    });
  }

  floatOrb('hero-orb-1', 80, 60, 6);
  floatOrb('hero-orb-2', 100, 80, 8);
  floatOrb('hero-orb-3', 60, 50, 7);

  // === SCAN LINE ===
  const scanline = document.getElementById('hero-scanline');
  if (scanline) {
    gsap.to(scanline, {
      top: '110%',
      duration: 4,
      ease: 'none',
      repeat: -1,
      delay: 2,
    });
  }

  // === LETTER STAGGER ON TITLE ===
  const titleEl = document.getElementById('hero-title');
  if (titleEl) {
    // Process text nodes into individual character spans
    const processNode = (node: ChildNode) => {
      if (node.nodeType === 3) { // text node
        const text = node.textContent || '';
        const fragment = document.createDocumentFragment();
        text.split('').forEach(char => {
          const span = document.createElement('span');
          span.textContent = char === ' ' ? '\u00A0' : char;
          span.style.display = 'inline-block';
          span.style.opacity = '0';
          span.classList.add('hero-char');
          fragment.appendChild(span);
        });
        node.parentNode?.replaceChild(fragment, node);
      }
    };

    // Process only direct text nodes, preserve child elements (like the gradient span)
    Array.from(titleEl.childNodes).forEach(child => {
      if (child.nodeType === 3) {
        processNode(child);
      } else if (child.nodeType === 1) {
        // It's an element (like the gradient-text span), process its text children
        Array.from(child.childNodes).forEach(grandChild => {
          if (grandChild.nodeType === 3) processNode(grandChild);
        });
      }
    });

    const chars = titleEl.querySelectorAll('.hero-char');
    gsap.from(chars, {
      y: 50,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      stagger: 0.03,
      delay: 1.7, // after preloader
      clearProps: 'opacity',
    });
  }

  // === ENTRANCE ANIMATIONS (delayed 1.7s for preloader) ===
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' }, delay: 1.7 });

  tl.from('#hero-tag', {
    y: 20, opacity: 0, duration: 0.6, clearProps: 'opacity',
  })
  // letter stagger plays separately (already set up)
  .from('#hero-content', {
    y: 40, opacity: 0, duration: 0.8, clearProps: 'opacity',
  }, '+=0.3')
  .from('#hero-brand', {
    y: 30, opacity: 0, duration: 1, clearProps: 'opacity',
  }, '-=0.4')
  .to('#hero-divider', {
    scaleX: 1, duration: 1.2, ease: 'power2.inOut',
  }, '-=0.6')
  .from('#hero-scroll', {
    opacity: 0, duration: 1, clearProps: 'opacity',
  }, '-=0.4');

  // === SCROLL INDICATOR PULSE ===
  gsap.to('#hero-scroll', {
    y: 5,
    duration: 1.5,
    ease: 'sine.inOut',
    repeat: -1,
    yoyo: true,
    delay: 3.5,
  });
</script>
