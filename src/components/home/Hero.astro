---
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, {
  titleStart: string;
  titleHighlight: string;
  titleEnd: string;
  subtitle: string;
  ctaDiscover: string;
  bannerSubtitle: string;
  bannerTagline: string;
}> = {
  ro: {
    titleStart: 'Construim potențialul ',
    titleHighlight: 'experiențelor digitale ',
    titleEnd: 'autonome',
    subtitle: 'Construim website-uri performante, aplicații web și automatizări AI. Zero overhead, comunicare directă, livrare rapidă.',
    ctaDiscover: 'Descoperă',
    bannerSubtitle: 'Ridică-ți afacerea cu soluțiile noastre inovatoare',
    bannerTagline: 'Soluții creative pentru afacerea ta',
  },
  en: {
    titleStart: 'Unlocking the potential of ',
    titleHighlight: 'autonomous digital ',
    titleEnd: 'experiences',
    subtitle: 'We build high-performance websites, web apps, and AI automations. Zero overhead, direct communication, fast delivery.',
    ctaDiscover: 'Discover',
    bannerSubtitle: 'Elevate your business with our innovative solutions',
    bannerTagline: 'Creative solutions for your business',
  },
};

const l = labels[locale];
---
<section id="hero-section" class="bg-base-950 relative overflow-hidden">
  <!-- Dot mesh background -->
  <div class="absolute inset-0 dot-mesh pointer-events-none" aria-hidden="true"></div>

  <!-- Mouse-following glow orb -->
  <div
    id="hero-mouse-glow"
    class="absolute w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(59,130,246,0.18) 0%, rgba(34,211,238,0.08) 35%, transparent 70%); filter: blur(60px); top: 50%; left: 50%; transform: translate(-50%, -50%);"
    aria-hidden="true"
  ></div>

  <!-- Freely floating orbs -->
  <div id="hero-orb-1" class="absolute w-[400px] h-[400px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(34,211,238,0.12) 0%, transparent 70%); filter: blur(80px); top: 20%; left: 15%;" aria-hidden="true"></div>
  <div id="hero-orb-2" class="absolute w-[350px] h-[350px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(59,130,246,0.10) 0%, transparent 70%); filter: blur(70px); top: 60%; right: 10%;" aria-hidden="true"></div>
  <div id="hero-orb-3" class="absolute w-[250px] h-[250px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 70%); filter: blur(50px); bottom: 15%; left: 40%;" aria-hidden="true"></div>

  <!-- Scan line effect -->
  <div id="hero-scanline" class="absolute left-0 right-0 h-[1px] pointer-events-none" style="background: linear-gradient(90deg, transparent 0%, rgba(59,130,246,0.3) 20%, rgba(34,211,238,0.5) 50%, rgba(59,130,246,0.3) 80%, transparent 100%); top: -10%; opacity: 0.6;" aria-hidden="true"></div>

  <!-- ===== HERO INFO ===== -->
  <div class="relative z-10 pt-24 pb-8 lg:pb-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-end">
        <!-- Left: gradient title (9 cols) -->
        <div class="lg:col-span-9">
          <h1
            class="font-bold text-white leading-[1.1]"
            style="font-size: clamp(2.5rem, 7vw, 70px); font-family: 'Sora', Arial, Helvetica, sans-serif;"
          >
            {l.titleStart}<span class="gradient-text">{l.titleHighlight}</span>{l.titleEnd}
          </h1>
        </div>
        <!-- Right: description + CTA (4 cols) -->
        <div class="lg:col-span-3" id="hero-content">
          <p class="text-base text-base-300 leading-relaxed">
            {l.subtitle}
          </p>
          <a
            href={localePath('services', locale)}
            class="btn-glow magnetic-btn text-base inline-flex items-center gap-2 mt-8 shrink-0 group"
          >
            {l.ctaDiscover}
            <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== VIDEO BANNER — FULL WIDTH ===== -->
  <div class="relative z-10 pb-8 px-4 sm:px-6 lg:px-8" id="hero-banner">
    <div class="w-full">
      <div class="relative overflow-hidden bg-gradient-to-br from-electric-600/20 via-electric-500/10 to-base-900 border border-white/5 rounded-2xl">
        <!-- Background image layer -->
        <div class="absolute inset-0">
          <img src="/images/services/ai-agents.svg" alt="" class="w-full h-full object-cover opacity-20 mix-blend-overlay" width="640" height="400" fetchpriority="high" decoding="async" />
          <div class="absolute inset-0 bg-gradient-to-r from-base-950/90 via-base-950/70 to-transparent"></div>
        </div>
        <!-- Banner content -->
        <div class="relative z-10 px-8 sm:px-12 lg:px-16 pt-12 lg:pt-16 pb-0">
          <!-- Top row: subtitle + play button -->
          <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-8">
            <span id="hero-banner-sub" class="text-electric-400 text-sm font-heading uppercase tracking-widest">
              {l.bannerSubtitle}
            </span>
            <a
              href={localePath('contact', locale)}
              class="inline-flex items-center gap-4 group shrink-0"
            >
              <span class="w-14 h-14 rounded-full border-2 border-electric-400/50 flex items-center justify-center group-hover:bg-electric-500 group-hover:border-electric-500 transition-all duration-300">
                <svg class="w-5 h-5 text-electric-400 group-hover:text-white transition-colors ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </span>
              <span class="text-base-300 group-hover:text-white transition-colors font-medium">
                {locale === 'ro' ? 'Vezi cum lucrăm' : 'See how we work'}
              </span>
            </a>
          </div>

          <p class="text-base-300 text-sm max-w-lg leading-relaxed">
            {locale === 'ro'
              ? 'Agenție web fondată pe principiul că tehnologia trebuie să fie rapidă, accesibilă și autonomă. Zero overhead — vorbești direct cu cine scrie codul.'
              : 'Web agency built on the principle that technology should be fast, accessible, and autonomous. Zero overhead — you talk directly to the people writing the code.'}
          </p>

          <!-- Large ISIO logo touching bottom -->
          <img src="/images/logo.svg" alt="ISIO" class="h-[5rem] sm:h-[7rem] lg:h-[10rem] w-auto" width="224" height="80" style="margin-bottom: -0.08em;" />
        </div>
      </div>
    </div>
  </div>

</section>

