---
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---
<section class="py-24 relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Left: image/visual area (5 cols like Aiero) -->
      <div class="lg:col-span-5 relative">
        <div class="aspect-[4/5] rounded-2xl bg-gradient-to-br from-electric-500/10 via-base-800 to-base-900 relative overflow-hidden">
          <!-- Placeholder for person/brand image -->
          <div class="absolute inset-0 dot-mesh opacity-40"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center">
              <div class="w-24 h-24 mx-auto rounded-full bg-gradient-to-br from-electric-500/30 to-cyan-400/20 flex items-center justify-center mb-4">
                <svg class="w-12 h-12 text-electric-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
              </div>
              <span class="text-base-400 text-sm font-heading">Est. 2019</span>
            </div>
          </div>
          <!-- Bottom gradient fade -->
          <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-base-950 to-transparent"></div>
        </div>
      </div>
      <!-- Right: content (7 cols like Aiero) -->
      <div class="lg:col-span-7 relative">
        <!-- Large ghost background text (Aiero style-text) -->
        <span
          class="absolute -top-8 -left-4 text-[6rem] lg:text-[8rem] font-bold font-heading leading-none tracking-tighter select-none pointer-events-none"
          style="-webkit-text-stroke: 1px rgba(255,255,255,0.04); color: transparent;"
          aria-hidden="true"
        >
          {locale === 'ro' ? 'Agenție' : 'Agency'}
        </span>
        <div class="relative z-10">
          <span class="section-tag">{locale === 'ro' ? '[ 04 ] despre' : '[ 04 ] about'}</span>
          <h2 class="mt-4 text-3xl sm:text-4xl font-bold font-heading text-white leading-tight">
            {locale === 'ro'
              ? 'Pionieri în soluții web autonome și inovație digitală'
              : 'Pioneers in autonomous web solutions and digital innovation'}
          </h2>
          <p class="mt-6 text-base-300 leading-relaxed">
            {locale === 'ro'
              ? 'Isio este o agenție web fondată de un dezvoltator full-stack cu peste 7 ani de experiență. De la marketplace-uri de accesibilitate la agenți AI autonomi, fiecare proiect este abordat cu aceeași atenție la detalii tehnice.'
              : 'Isio is a web agency founded by a full-stack developer with 7+ years of experience. From accessibility marketplaces to autonomous AI agents, every project receives the same attention to technical detail.'}
          </p>
          <p class="mt-4 text-base-400 leading-relaxed">
            {locale === 'ro'
              ? 'Filosofia noastră: să livrăm soluții care funcționează independent, cu cod curat, performanță excepțională și accesibilitate de la prima linie de cod.'
              : 'Our philosophy: deliver solutions that run independently, with clean code, exceptional performance, and accessibility from the first line of code.'}
          </p>
          <a href={localePath('about', locale)} class="mt-8 btn-outline inline-flex items-center gap-2 group">
            {locale === 'ro' ? 'Află mai mult' : 'Explore More'}
            <svg class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
