---
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const techs = [
  { name: 'Astro', icon: '🚀' },
  { name: 'TypeScript', icon: '💎' },
  { name: 'Tailwind CSS', icon: '🎨' },
  { name: 'React', icon: '⚛️' },
  { name: 'Node.js', icon: '🟢' },
  { name: 'PostgreSQL', icon: '🐘' },
  { name: 'Sanity CMS', icon: '📝' },
  { name: 'Cloudflare', icon: '☁️' },
];
---
<section class="py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Left: icon/visual (2 cols like Aiero) -->
      <div class="lg:col-span-2">
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-electric-500/20 to-cyan-400/10 flex items-center justify-center">
          <svg class="w-10 h-10 text-electric-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
      </div>
      <!-- Right: text + carousel (10 cols like Aiero) -->
      <div class="lg:col-span-10">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold font-heading text-white leading-tight mb-12">
          {locale === 'ro'
            ? <Fragment>Construim cu <span class="gradient-text">tehnologii moderne</span> care performează la scară.</Fragment>
            : <Fragment>We build with <span class="gradient-text">modern technologies</span> that perform at scale.</Fragment>
          }
        </h2>
        <!-- Tech carousel grid -->
        <div class="grid grid-cols-4 sm:grid-cols-8 gap-4">
          {techs.map((tech) => (
            <div class="glass-card p-4 flex flex-col items-center justify-center gap-2 group hover:border-white/10 transition-all">
              <span class="text-2xl">{tech.icon}</span>
              <span class="text-xs text-base-400 group-hover:text-white transition-colors font-medium">{tech.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
