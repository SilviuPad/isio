---
interface Props {
  title: string;
  description: string;
  screenshot: string;
  techStack: string[];
  liveUrl: string;
}

const { title, description, screenshot, techStack, liveUrl } = Astro.props;
---

<div class="glass-card overflow-hidden group" data-animate>
  <!-- Screenshot area -->
  <div class="bg-base-800 h-56 flex items-center justify-center overflow-hidden relative">
    {screenshot ? (
      <img
        src={screenshot}
        alt={title}
        width="640"
        height="224"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <span class="text-base-500 text-sm">Screenshot</span>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-base-950/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" aria-hidden="true"></div>
  </div>

  <!-- Content area -->
  <div class="p-6">
    <h3 class="text-xl font-bold font-heading text-white">{title}</h3>
    <p class="text-base-300 text-sm mt-2">{description}</p>

    <!-- Tech stack -->
    <div class="flex flex-wrap gap-2 mt-4">
      {techStack.map((tech) => (
        <span class="bg-white/5 text-base-300 text-xs px-3 py-1 rounded-full border border-white/10 font-medium">{tech}</span>
      ))}
    </div>

    <!-- Live link -->
    <a
      href={liveUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 mt-4 text-electric-400 hover:text-electric-300 text-sm font-semibold transition-colors"
    >
      <span>Vezi proiectul / View project</span>
      <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</div>
