---
import type { Locale } from '../../i18n/utils';
import { localePath } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { pricing: string; contact: string; heading: string; subheading: string }> = {
  ro: {
    heading: 'Gata să începi?',
    subheading: 'Alege pachetul potrivit sau programează o consultație gratuită.',
    pricing: 'Vezi prețurile',
    contact: 'Programează un apel',
  },
  en: {
    heading: 'Ready to get started?',
    subheading: 'Choose the right plan or schedule a free consultation.',
    pricing: 'View pricing',
    contact: 'Book a call',
  },
};

const t = labels[locale];
---

<section class="bg-navy-50 rounded-2xl p-12 mt-16 text-center">
  <h2 class="text-3xl font-bold font-heading text-navy-950">{t.heading}</h2>
  <p class="mt-4 text-lg text-navy-500 max-w-xl mx-auto">{t.subheading}</p>
  <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
    <a
      href={localePath('pricing', locale)}
      class="bg-electric-500 hover:bg-electric-600 text-white px-8 py-4 rounded-full font-semibold transition-colors duration-200 inline-block"
    >
      {t.pricing}
    </a>
    <a
      href={localePath('contact', locale)}
      class="border-2 border-navy-300 text-navy-700 hover:border-electric-500 hover:text-electric-500 px-8 py-4 rounded-full font-semibold transition-colors duration-200 inline-block"
    >
      {t.contact}
    </a>
  </div>
</section>
