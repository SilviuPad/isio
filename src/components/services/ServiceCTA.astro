---
import type { Locale } from '../../i18n/utils';
import { localePath } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { pricing: string; contact: string; heading: string; subheading: string }> = {
  ro: {
    heading: 'Gata să începi?',
    subheading: 'Alege pachetul potrivit sau programează o consultație gratuită.',
    pricing: 'Vezi prețurile',
    contact: 'Programează un apel',
  },
  en: {
    heading: 'Ready to get started?',
    subheading: 'Choose the right plan or schedule a free consultation.',
    pricing: 'View pricing',
    contact: 'Book a call',
  },
};

const t = labels[locale];
---

<section class="glass-card p-12 mt-16 text-center relative overflow-hidden" data-animate>
  <div class="radial-glow absolute inset-0 pointer-events-none opacity-60" aria-hidden="true"></div>
  <div class="relative z-10">
    <h2 class="text-3xl font-bold font-heading text-white">{t.heading}</h2>
    <p class="mt-4 text-lg text-base-300 max-w-xl mx-auto">{t.subheading}</p>
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={localePath('pricing', locale)}
        class="btn-glow inline-block"
      >
        {t.pricing}
      </a>
      <a
        href={localePath('contact', locale)}
        class="btn-outline inline-block"
      >
        {t.contact}
      </a>
    </div>
  </div>
</section>
