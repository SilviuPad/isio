---
import type { Locale } from '../../i18n/utils';
import { getServiceByKey, localize } from '../../lib/content';
import { getServiceDetail } from '../../lib/service-data';
import ServiceFeatureList from './ServiceFeatureList.astro';
import ServiceCTA from './ServiceCTA.astro';

interface Props {
  serviceKey: string;
  locale: Locale;
}

const { serviceKey, locale } = Astro.props;

const service = await getServiceByKey(serviceKey);
const detail = getServiceDetail(serviceKey);

const title = service ? localize(service.title, locale) : serviceKey;
const description = service ? localize(service.description, locale) : '';
const tagline = detail ? detail.tagline[locale] : description;
const turnaround = detail ? detail.turnaroundDays[locale] : '';

const turnaroundLabel: Record<Locale, string> = {
  ro: 'Timp de livrare',
  en: 'Turnaround time',
};
---

<!-- Hero -->
<section class="bg-base-950 dot-mesh py-24 relative overflow-hidden">
  <div class="radial-glow absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <span class="section-tag" data-animate>Servicii</span>
    <h1 class="text-4xl font-bold font-heading text-white sm:text-5xl mt-4" data-animate>{title}</h1>
    <p class="mt-6 text-xl text-base-300 max-w-2xl" data-animate>{tagline}</p>
  </div>
</section>

<!-- Content sections -->
<div class="bg-base-950">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    {detail && detail.sections.map((section) => (
      <div class="glass-card p-8 mb-8" data-animate>
        <h2 class="text-2xl font-bold font-heading text-white mb-6">
          {section.title[locale]}
        </h2>
        {section.prose && section.prose.length > 0 && (
          <div class="space-y-4 mb-8">
            {section.prose.map((p) => (
              <p class="text-base-300 leading-relaxed">{p[locale]}</p>
            ))}
          </div>
        )}
        <ServiceFeatureList items={section.items} locale={locale} />
      </div>
    ))}

    <!-- Turnaround block -->
    {turnaround && (
      <div class="glass-card p-8 mb-8 border-l-4 border-electric-500" data-animate>
        <p class="text-base-400 text-sm font-semibold uppercase tracking-wider mb-2">
          {turnaroundLabel[locale]}
        </p>
        <p class="gradient-text font-bold text-3xl font-heading">{turnaround}</p>
      </div>
    )}

    {/* FAQ Section */}
    {detail && detail.faq && detail.faq.length > 0 && (
      <div class="glass-card p-8 mb-8" data-animate>
        <h2 class="text-2xl font-bold font-heading text-white mb-8">
          {locale === 'ro' ? 'Intrebari frecvente' : 'Frequently asked questions'}
        </h2>
        <div class="space-y-6">
          {detail.faq.map((item) => (
            <details class="group border-b border-white/10 pb-6 last:border-b-0 last:pb-0">
              <summary class="flex items-center justify-between cursor-pointer text-base-200 font-semibold hover:text-white transition-colors">
                <span>{item.question[locale]}</span>
                <svg class="w-5 h-5 shrink-0 ml-4 text-electric-400 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-base-400 leading-relaxed">{item.answer[locale]}</p>
            </details>
          ))}
        </div>
      </div>
    )}

    <!-- Dual CTA -->
    <ServiceCTA locale={locale} />
  </div>
</div>
