---
import type { Locale } from '../../i18n/utils';

interface Props {
  items: Array<{ text: { ro: string; en: string } }>;
  locale: Locale;
}

const { items, locale } = Astro.props;
---

<ul class="space-y-4">
  {items.map((item) => (
    <li class="flex items-start gap-3 group transition-all duration-200 rounded-lg p-2 -mx-2 hover:bg-white/5">
      <svg
        class="text-electric-400 w-5 h-5 mt-0.5 shrink-0 transition-transform duration-200 group-hover:scale-110"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
          clip-rule="evenodd"
        />
      </svg>
      <span class="text-base-200">{item.text[locale]}</span>
    </li>
  ))}
</ul>
