---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon } = Astro.props;
---
<a
  href={href}
  class="block p-6 bg-navy-800 rounded-xl hover:bg-navy-700 transition-colors group"
>
  {icon && (
    <span class="text-2xl mb-4 block">{icon}</span>
  )}
  <h3 class="text-lg font-semibold font-heading text-white group-hover:text-electric-400 transition-colors">
    {title}
  </h3>
  <p class="mt-2 text-navy-300 text-sm leading-relaxed">
    {description}
  </p>
  <span class="mt-4 inline-flex items-center text-electric-400 text-sm font-medium">
    Află mai mult
    <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
