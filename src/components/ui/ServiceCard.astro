---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon } = Astro.props;
---
<a
  href={href}
  class="glass-card p-6 group cursor-pointer transition-all duration-300 block"
  data-animate
>
  {icon && (
    <span class="text-2xl mb-4 block">{icon}</span>
  )}
  <h3 class="text-lg font-semibold font-heading text-white group-hover:text-electric-400 transition-colors duration-300">
    {title}
  </h3>
  <p class="mt-2 text-base-300 text-sm leading-relaxed">
    {description}
  </p>
  <span class="mt-4 inline-flex items-center text-electric-400 text-sm font-medium">
    Află mai mult
    <svg
      class="ml-1 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
