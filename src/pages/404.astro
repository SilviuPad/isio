---
import Base from '../layouts/Base.astro';
import { getLocaleFromUrl } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const content: Record<Locale, { title: string; message: string; backHome: string; homeHref: string }> = {
  ro: {
    title: 'Pagina nu a fost găsită',
    message: 'Ne pare rău, pagina pe care o cauți nu există.',
    backHome: 'Înapoi acasă',
    homeHref: '/',
  },
  en: {
    title: 'Page not found',
    message: 'Sorry, the page you are looking for does not exist.',
    backHome: 'Back to home',
    homeHref: '/en/',
  },
};

const text = content[locale];
---
<Base title={`404 — ${text.title}`} locale={locale} roSlug="/" enSlug="/en/">
  <div class="flex min-h-screen items-center justify-center px-4">
    <div class="text-center">
      <p class="text-6xl font-bold text-base-200">404</p>
      <h1 class="mt-4 text-2xl font-bold text-base-100">{text.title}</h1>
      <p class="mt-2 text-base-400">{text.message}</p>
      <a href={text.homeHref} class="mt-6 inline-block rounded-md bg-accent-500 px-4 py-2 text-sm font-medium text-white hover:bg-accent-600 transition-colors">
        {text.backHome}
      </a>
      {locale === 'ro' && (
        <p class="mt-4">
          <a href="/en/" class="text-sm text-base-500 hover:text-base-300">English version</a>
        </p>
      )}
      {locale === 'en' && (
        <p class="mt-4">
          <a href="/" class="text-sm text-base-500 hover:text-base-300">Versiunea română</a>
        </p>
      )}
    </div>
  </div>
</Base>
