---
export const prerender = true;

import Page from '../layouts/Page.astro';
import PricingServiceGroup from '../components/pricing/PricingServiceGroup.astro';
import { getServices, getAllPricingTiers, localize } from '../lib/content';
import { slugMap } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

const locale: Locale = 'ro';
const { roSlug, enSlug } = { roSlug: slugMap.pricing.ro, enSlug: slugMap.pricing.en };

const services = await getServices();
const allTiers = await getAllPricingTiers();

// Group tiers by service key
const tiersByService = new Map<string, typeof allTiers>();
for (const tier of allTiers) {
  const existing = tiersByService.get(tier.service) ?? [];
  existing.push(tier);
  tiersByService.set(tier.service, existing);
}
---
<Page
  title="Prețuri — ISIO"
  description="Pachete transparente pentru fiecare serviciu — website, aplicații web, SEO, accesibilitate și agenți AI."
  locale={locale}
  roSlug={roSlug}
  enSlug={enSlug}
  pageType="pricing"
>
  <!-- Hero -->
  <section class="bg-base-950 dot-mesh py-24 relative overflow-hidden">
    <div class="radial-glow absolute inset-0 pointer-events-none" aria-hidden="true"></div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <span class="section-tag">Prețuri</span>
      <h1 class="text-4xl sm:text-5xl font-bold font-heading text-white mt-4">Prețuri transparente</h1>
      <p class="mt-6 text-xl text-base-300 max-w-2xl mx-auto">
        Pachete clare pentru fiecare serviciu. Fără surprize, fără costuri ascunse.
      </p>
    </div>
  </section>

  <!-- Pricing sections -->
  <section class="bg-base-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24">
      {services.map((service) => {
        const tiers = tiersByService.get(service.serviceKey) ?? [];
        if (tiers.length === 0) return null;
        return (
          <PricingServiceGroup
            serviceKey={service.serviceKey}
            serviceName={localize(service.title, locale)}
            tiers={tiers}
            locale={locale}
          />
        );
      })}
    </div>
  </section>
</Page>
