---
export const prerender = true;

import Page from '../layouts/Page.astro';
import { slugMap, localePath } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

const locale: Locale = 'ro';
const { roSlug, enSlug } = { roSlug: slugMap.contact.ro, enSlug: slugMap.contact.en };
---
<Page title="Contact — ISIO" description="Contactează-ne pentru a discuta proiectul tău. Programează un apel de descoperire gratuit." locale={locale} roSlug={roSlug} enSlug={enSlug} pageType="contact">
  <!-- Hero -->
  <section class="bg-base-950 dot-mesh py-24 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%); filter: blur(60px);"></div>
    </div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      <span class="section-tag">[ contact ]</span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-bold font-heading text-white" data-animate>Contact</h1>
      <p class="mt-6 text-xl text-base-300 max-w-2xl" data-animate>
        Hai să discutăm despre proiectul tău.
      </p>
    </div>
  </section>

  <!-- Contact form + info -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Form -->
      <div data-animate>
        <h2 class="text-2xl font-bold font-heading text-white">Trimite un mesaj</h2>
        <p class="mt-2 text-base-400 text-sm">Răspundem în maxim 24 de ore.</p>
        <form class="mt-8 space-y-6" id="contact-form" data-locale="ro">
          <div>
            <label for="name" class="block text-sm font-medium text-base-200 mb-2">Nume</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors"
              placeholder="Numele tău"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-base-200 mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors"
              placeholder="email@exemplu.ro"
            />
          </div>
          <div>
            <label for="service" class="block text-sm font-medium text-base-200 mb-2">Serviciu (opțional)</label>
            <select
              id="service"
              name="service"
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors appearance-none"
            >
              <option value="" class="bg-base-900">Selectează un serviciu</option>
              <option value="web-development" class="bg-base-900">Dezvoltare Website</option>
              <option value="web-apps" class="bg-base-900">Aplicații Web</option>
              <option value="seo" class="bg-base-900">SEO</option>
              <option value="accessibility" class="bg-base-900">Accesibilitate</option>
              <option value="ai-agents" class="bg-base-900">Implementare Agenți AI</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-base-200 mb-2">Mesaj</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors resize-none"
              placeholder="Descrie proiectul tău..."
            ></textarea>
          </div>
          {import.meta.env.PUBLIC_TURNSTILE_SITE_KEY && (
            <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY} data-theme="dark" data-size="invisible"></div>
          )}
          <button type="submit" class="btn-glow w-full text-center">
            Trimite mesajul
          </button>
        </form>
        <div id="form-status" class="mt-4 hidden"></div>
      </div>

      <!-- Info side -->
      <div class="space-y-8" data-animate>
        <div class="glass-card p-8">
          <h3 class="text-lg font-bold font-heading text-white">Programează un apel de descoperire</h3>
          <p class="mt-3 text-base-300 text-sm leading-relaxed mb-6">
            Alege o dată și oră convenabilă pentru un apel gratuit de 30 de minute.
          </p>
          <div id="cal-embed" style="width:100%; overflow:hidden; min-height:600px;"></div>
        </div>

        <div class="glass-card p-8">
          <h3 class="text-lg font-bold font-heading text-white">Informații</h3>
          <div class="mt-4 space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-electric-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="text-sm text-base-400">Email</p>
                <a href="mailto:contact@isio.ro" class="text-white hover:text-electric-400 transition-colors">contact@isio.ro</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-electric-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="text-sm text-base-400">Locație</p>
                <p class="text-white">România — remote worldwide</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-electric-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="text-sm text-base-400">Timp de răspuns</p>
                <p class="text-white">Sub 24 de ore</p>
              </div>
            </div>
          </div>
        </div>

        <div class="glass-card p-8">
          <h3 class="text-lg font-bold font-heading text-white">Proces</h3>
          <div class="mt-4 space-y-4">
            {[
              { step: '01', text: 'Apel de descoperire — înțelegem cerințele' },
              { step: '02', text: 'Propunere — soluție tehnică și timeline' },
              { step: '03', text: 'Dezvoltare — iterații cu feedback' },
              { step: '04', text: 'Lansare — deploy și suport post-launch' },
            ].map((item) => (
              <div class="flex items-start gap-4">
                <span class="gradient-text font-heading font-bold text-sm">{item.step}</span>
                <p class="text-base-300 text-sm">{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function (C, A, L) {
      var p = function (a, ar) { a.q.push(ar); };
      var d = C.document;
      C.Cal = C.Cal || function () { var cal = C.Cal; var ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { var api = function () { p(api, arguments); }; var namespace = ar[1]; api.q = api.q || []; if (typeof namespace === "string") { cal.ns[namespace] = cal.ns[namespace] || api; p(cal.ns[namespace], ar); p(cal, ["init498498for498namespace", namespace, api]); } else p(cal, ar); return; } p(cal, ar); };
    })(window, "https://cal.eu/embed/embed.js", "init");
    Cal("init", { origin: "https://cal.eu" });
    Cal("inline", {
      elementOrSelector: "#cal-embed",
      calLink: "isioserv/discovery-call",
      layout: "month_view",
      config: {
        theme: "dark",
        lang: "ro"
      }
    });
    Cal("ui", {
      theme: "dark",
      cssVarsPerTheme: {
        dark: { "cal-brand": "#3b82f6" }
      },
      hideEventTypeDetails: true
    });
  </script>

  {import.meta.env.PUBLIC_TURNSTILE_SITE_KEY && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}

  <script is:inline>
    (function () {
      var form = document.getElementById('contact-form');
      var statusEl = document.getElementById('form-status');
      if (!form || !statusEl) return;

      var locale = form.getAttribute('data-locale') || 'ro';

      var strings = {
        ro: {
          loading: 'Se trimite...',
          submit: 'Trimite mesajul',
          success: 'Mesajul a fost trimis! Revenim in maxim 24 de ore.',
          error: 'Nu am putut trimite mesajul. Te rugam incearca din nou.',
        },
        en: {
          loading: 'Sending...',
          submit: 'Send message',
          success: "Message sent! We'll get back to you within 24 hours.",
          error: 'Could not send message. Please try again.',
        },
      };

      var t = strings[locale] || strings.ro;

      // Pre-fill from pricing page query params
      var params = new URLSearchParams(window.location.search);
      var paramService = params.get('service');
      var paramPackage = params.get('package');
      if (paramService) {
        var serviceSelect = form.querySelector('[name="service"]');
        if (serviceSelect) serviceSelect.value = paramService;
      }
      if (paramPackage) {
        var msgField = form.querySelector('[name="message"]');
        if (msgField && !msgField.value) {
          msgField.value = locale === 'ro'
            ? 'Sunt interesat de pachetul ' + paramPackage + '.'
            : "I'm interested in the " + paramPackage + ' package.';
        }
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();

        var submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = t.loading;
        }

        statusEl.className = 'mt-4 hidden';
        statusEl.textContent = '';

        var nameEl = form.querySelector('[name="name"]');
        var emailEl = form.querySelector('[name="email"]');
        var serviceEl = form.querySelector('[name="service"]');
        var messageEl = form.querySelector('[name="message"]');
        var turnstileEl = form.querySelector('[name="cf-turnstile-response"]');

        var payload = {
          name: nameEl ? nameEl.value : '',
          email: emailEl ? emailEl.value : '',
          service: serviceEl ? serviceEl.value : '',
          message: messageEl ? messageEl.value : '',
          turnstileToken: turnstileEl ? turnstileEl.value : '',
          locale: locale,
        };

        fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })
          .then(function (res) {
            return res.json().then(function (data) {
              return { ok: res.ok, data: data };
            });
          })
          .then(function (result) {
            if (result.ok) {
              form.style.display = 'none';
              statusEl.className = 'mt-4 p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400';
              statusEl.textContent = t.success;
            } else {
              statusEl.className = 'mt-4 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400';
              statusEl.textContent = t.error;
              if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.textContent = t.submit;
              }
              if (typeof turnstile !== 'undefined') {
                turnstile.reset();
              }
            }
          })
          .catch(function () {
            statusEl.className = 'mt-4 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400';
            statusEl.textContent = t.error;
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = t.submit;
            }
            if (typeof turnstile !== 'undefined') {
              turnstile.reset();
            }
          });
      });
    })();
  </script>
</Page>
