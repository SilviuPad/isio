---
export const prerender = true;

import Page from '../layouts/Page.astro';
import { slugMap, localePath } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

const locale: Locale = 'ro';
const { roSlug, enSlug } = { roSlug: slugMap.contact.ro, enSlug: slugMap.contact.en };
---
<Page title="Contact — Isio" description="Contactează-ne pentru a discuta proiectul tău. Programează un apel de descoperire gratuit." locale={locale} roSlug={roSlug} enSlug={enSlug}>
  <!-- Hero -->
  <section class="bg-base-950 dot-mesh py-24 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%); filter: blur(60px);"></div>
    </div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      <span class="section-tag">[ contact ]</span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-bold font-heading text-white" data-animate>Contact</h1>
      <p class="mt-6 text-xl text-base-300 max-w-2xl" data-animate>
        Hai să discutăm despre proiectul tău.
      </p>
    </div>
  </section>

  <!-- Contact form + info -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Form -->
      <div data-animate>
        <h2 class="text-2xl font-bold font-heading text-white">Trimite un mesaj</h2>
        <p class="mt-2 text-base-400 text-sm">Răspundem în maxim 24 de ore.</p>
        <form class="mt-8 space-y-6" id="contact-form">
          <div>
            <label for="name" class="block text-sm font-medium text-base-200 mb-2">Nume</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors"
              placeholder="Numele tău"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-base-200 mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors"
              placeholder="email@exemplu.ro"
            />
          </div>
          <div>
            <label for="service" class="block text-sm font-medium text-base-200 mb-2">Serviciu (opțional)</label>
            <select
              id="service"
              name="service"
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors appearance-none"
            >
              <option value="" class="bg-base-900">Selectează un serviciu</option>
              <option value="web-development" class="bg-base-900">Dezvoltare Website</option>
              <option value="web-apps" class="bg-base-900">Aplicații Web</option>
              <option value="seo" class="bg-base-900">SEO</option>
              <option value="accessibility" class="bg-base-900">Accesibilitate</option>
              <option value="ai-agents" class="bg-base-900">Implementare Agenți AI</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-base-200 mb-2">Mesaj</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors resize-none"
              placeholder="Descrie proiectul tău..."
            ></textarea>
          </div>
          <button type="submit" class="btn-glow w-full text-center">
            Trimite mesajul
          </button>
        </form>
      </div>

      <!-- Info side -->
      <div class="space-y-8" data-animate>
        <div class="glass-card p-8">
          <h3 class="text-lg font-bold font-heading text-white">Programează un apel</h3>
          <p class="mt-3 text-base-300 text-sm leading-relaxed">
            Preferi să discutăm direct? Programează un apel de descoperire gratuit de 30 de minute
            pentru a analiza cerințele proiectului tău.
          </p>
          <a
            href={localePath('contact', locale)}
            class="btn-outline inline-block mt-6 text-sm"
          >
            Programează apelul
          </a>
        </div>

        <div class="glass-card p-8">
          <h3 class="text-lg font-bold font-heading text-white">Informații</h3>
          <div class="mt-4 space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-electric-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="text-sm text-base-400">Email</p>
                <a href="mailto:contact@isio.ro" class="text-white hover:text-electric-400 transition-colors">contact@isio.ro</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-electric-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="text-sm text-base-400">Locație</p>
                <p class="text-white">România — remote worldwide</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-electric-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="text-sm text-base-400">Timp de răspuns</p>
                <p class="text-white">Sub 24 de ore</p>
              </div>
            </div>
          </div>
        </div>

        <div class="glass-card p-8">
          <h3 class="text-lg font-bold font-heading text-white">Proces</h3>
          <div class="mt-4 space-y-4">
            {[
              { step: '01', text: 'Apel de descoperire — înțelegem cerințele' },
              { step: '02', text: 'Propunere — soluție tehnică și timeline' },
              { step: '03', text: 'Dezvoltare — iterații cu feedback' },
              { step: '04', text: 'Lansare — deploy și suport post-launch' },
            ].map((item) => (
              <div class="flex items-start gap-4">
                <span class="gradient-text font-heading font-bold text-sm">{item.step}</span>
                <p class="text-base-300 text-sm">{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Page>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray('[data-animate]').forEach((el) => {
    gsap.from(el as Element, {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: { trigger: el as Element, start: 'top 85%' },
    });
  });
</script>
