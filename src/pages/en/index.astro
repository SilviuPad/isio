---
export const prerender = true;

import Page from '../../layouts/Page.astro';
import { slugMap } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

const locale: Locale = 'en';
const { roSlug, enSlug } = { roSlug: slugMap.home.ro, enSlug: slugMap.home.en };
---
<Page
  title="Isio — Web Agency"
  description="Web agency specializing in website development, web apps, SEO, and accessibility audits."
  locale={locale}
  roSlug={roSlug}
  enSlug={enSlug}
>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
      Isio Web Agency
    </h1>
    <p class="mt-6 text-lg text-gray-600 max-w-2xl">
      We build websites, web apps, and provide SEO and accessibility services.
    </p>
    <p class="mt-4 text-sm text-gray-400">
      [Foundation page — full content coming in Phase 2]
    </p>
  </section>
</Page>
