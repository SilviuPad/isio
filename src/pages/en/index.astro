---
export const prerender = true;

import Page from '../../layouts/Page.astro';
import Hero from '../../components/home/Hero.astro';
import ServicesPreview from '../../components/home/ServicesPreview.astro';
import Marquee from '../../components/home/Marquee.astro';
import Features from '../../components/home/Features.astro';
import AboutPreview from '../../components/home/AboutPreview.astro';
import Stats from '../../components/home/Stats.astro';
import ServiceBlocks from '../../components/home/ServiceBlocks.astro';
import Testimonials from '../../components/home/Testimonials.astro';
import FAQ from '../../components/home/FAQ.astro';
import Partners from '../../components/home/Partners.astro';
import ContactInline from '../../components/home/ContactInline.astro';
import CallToAction from '../../components/home/CallToAction.astro';
import { slugMap } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

const locale: Locale = 'en';
const { roSlug, enSlug } = { roSlug: slugMap.home.ro, enSlug: slugMap.home.en };
---
<Page
  title="Isio — Web Agency"
  description="Web agency specializing in website development, web apps, SEO, and accessibility audits."
  locale={locale}
  roSlug={roSlug}
  enSlug={enSlug}
  pageType="home"
>
  <Hero locale={locale} />
  <ServicesPreview locale={locale} />
  <Marquee locale={locale} />
  <Features locale={locale} />
  <AboutPreview locale={locale} />
  <Stats locale={locale} />
  <ServiceBlocks locale={locale} />
  <Testimonials locale={locale} />
  <FAQ locale={locale} />
  <Partners locale={locale} />
  <ContactInline locale={locale} />
  <CallToAction locale={locale} />
</Page>
