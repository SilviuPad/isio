---
export const prerender = true;

import Page from '../../layouts/Page.astro';
import { slugMap } from '../../i18n/utils';
import { getAllPricingTiers, localize } from '../../lib/sanity';
import type { Locale } from '../../i18n/utils';

const locale: Locale = 'en';
const { roSlug, enSlug } = { roSlug: slugMap.pricing.ro, enSlug: slugMap.pricing.en };

let tiers = [];
try {
  tiers = await getAllPricingTiers();
} catch (e) {
  console.warn('Sanity fetch failed (expected during initial setup):', e instanceof Error ? e.message : e);
}
---
<Page
  title="Pricing — Isio"
  description="Pricing packages for web development, web apps, SEO, and accessibility services."
  locale={locale}
  roSlug={roSlug}
  enSlug={enSlug}
>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Pricing</h1>
    {tiers.length > 0 ? (
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {tiers.map((tier) => (
          <div class="rounded-lg border border-gray-200 p-6">
            <h3 class="text-lg font-semibold">{localize(tier.name, locale)}</h3>
            <p class="mt-2 text-2xl font-bold">{tier.priceEur} EUR</p>
            <p class="mt-1 text-sm text-gray-500">{tier.deliveryDays} day delivery</p>
          </div>
        ))}
      </div>
    ) : (
      <p class="mt-6 text-gray-500">
        [Pricing will be loaded from CMS once the Sanity project is configured]
      </p>
    )}
  </section>
</Page>
