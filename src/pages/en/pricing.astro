---
export const prerender = true;

import Page from '../../layouts/Page.astro';
import PricingServiceGroup from '../../components/pricing/PricingServiceGroup.astro';
import { getServices, getAllPricingTiers, localize } from '../../lib/content';
import { slugMap } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

const locale: Locale = 'en';
const { roSlug, enSlug } = { roSlug: slugMap.pricing.ro, enSlug: slugMap.pricing.en };

const services = await getServices();
const allTiers = await getAllPricingTiers();

// Group tiers by service key
const tiersByService = new Map<string, typeof allTiers>();
for (const tier of allTiers) {
  const existing = tiersByService.get(tier.service) ?? [];
  existing.push(tier);
  tiersByService.set(tier.service, existing);
}
---
<Page
  title="Pricing — Isio"
  description="Transparent packages for every service — website development, web apps, SEO, accessibility, and AI agents."
  locale={locale}
  roSlug={roSlug}
  enSlug={enSlug}
>
  <!-- Hero -->
  <section class="bg-navy-950 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold font-heading text-white">Pricing</h1>
      <p class="mt-6 text-xl text-navy-300 max-w-2xl mx-auto">
        Transparent packages for every service. No surprises, no hidden costs.
      </p>
    </div>
  </section>

  <!-- Pricing sections -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24">
    {services.map((service) => {
      const tiers = tiersByService.get(service.serviceKey) ?? [];
      if (tiers.length === 0) return null;
      return (
        <PricingServiceGroup
          serviceKey={service.serviceKey}
          serviceName={localize(service.title, locale)}
          tiers={tiers}
          locale={locale}
        />
      );
    })}
  </section>
</Page>
