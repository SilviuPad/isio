---
export const prerender = true;

import Page from '../../layouts/Page.astro';
import { slugMap, localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

const locale: Locale = 'en';
const { roSlug, enSlug } = { roSlug: slugMap.contact.ro, enSlug: slugMap.contact.en };
---
<Page title="Contact — Isio" description="Get in touch to discuss your project. Schedule a free discovery call." locale={locale} roSlug={roSlug} enSlug={enSlug}>
  <!-- Hero -->
  <section class="bg-base-950 dot-mesh py-24 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%); filter: blur(60px);"></div>
    </div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      <span class="section-tag">[ contact ]</span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-bold font-heading text-white" data-animate>Contact</h1>
      <p class="mt-6 text-xl text-base-300 max-w-2xl" data-animate>
        Let's talk about your project.
      </p>
    </div>
  </section>

  <!-- Contact form + info -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Form -->
      <div data-animate>
        <h2 class="text-2xl font-bold font-heading text-white">Send a message</h2>
        <p class="mt-2 text-base-400 text-sm">We respond within 24 hours.</p>
        <form class="mt-8 space-y-6" id="contact-form">
          <div>
            <label for="name" class="block text-sm font-medium text-base-200 mb-2">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-base-200 mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors"
              placeholder="email@example.com"
            />
          </div>
          <div>
            <label for="service" class="block text-sm font-medium text-base-200 mb-2">Service (optional)</label>
            <select
              id="service"
              name="service"
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors appearance-none"
            >
              <option value="" class="bg-base-900">Select a service</option>
              <option value="web-development" class="bg-base-900">Website Development</option>
              <option value="web-apps" class="bg-base-900">Web Applications</option>
              <option value="seo" class="bg-base-900">SEO</option>
              <option value="accessibility" class="bg-base-900">Accessibility</option>
              <option value="ai-agents" class="bg-base-900">AI Agent Implementation</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-base-200 mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-base-500 focus:border-electric-400 focus:ring-1 focus:ring-electric-400 focus:outline-none transition-colors resize-none"
              placeholder="Tell us about your project..."
            ></textarea>
          </div>
          <button type="submit" class="btn-glow w-full text-center">
            Send message
          </button>
        </form>
      </div>

      <!-- Info side -->
      <div class="space-y-8" data-animate>
        <div class="glass-card p-8">
          <h3 class="text-lg font-bold font-heading text-white">Schedule a call</h3>
          <p class="mt-3 text-base-300 text-sm leading-relaxed">
            Prefer to talk directly? Schedule a free 30-minute discovery call
            to discuss your project requirements.
          </p>
          <a
            href={localePath('contact', locale)}
            class="btn-outline inline-block mt-6 text-sm"
          >
            Schedule a call
          </a>
        </div>

        <div class="glass-card p-8">
          <h3 class="text-lg font-bold font-heading text-white">Information</h3>
          <div class="mt-4 space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-electric-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="text-sm text-base-400">Email</p>
                <a href="mailto:contact@isio.ro" class="text-white hover:text-electric-400 transition-colors">contact@isio.ro</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-electric-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="text-sm text-base-400">Location</p>
                <p class="text-white">Romania — remote worldwide</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-electric-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="text-sm text-base-400">Response time</p>
                <p class="text-white">Under 24 hours</p>
              </div>
            </div>
          </div>
        </div>

        <div class="glass-card p-8">
          <h3 class="text-lg font-bold font-heading text-white">Process</h3>
          <div class="mt-4 space-y-4">
            {[
              { step: '01', text: 'Discovery call — understand requirements' },
              { step: '02', text: 'Proposal — technical solution and timeline' },
              { step: '03', text: 'Development — iterations with feedback' },
              { step: '04', text: 'Launch — deploy and post-launch support' },
            ].map((item) => (
              <div class="flex items-start gap-4">
                <span class="gradient-text font-heading font-bold text-sm">{item.step}</span>
                <p class="text-base-300 text-sm">{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Page>
