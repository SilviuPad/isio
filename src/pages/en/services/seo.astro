---
export const prerender = true;

import Page from '../../../layouts/Page.astro';
import ServicePageLayout from '../../../components/services/ServicePageLayout.astro';
import { getServiceByKey, localize } from '../../../lib/content';
import { slugMap } from '../../../i18n/utils';
import type { Locale } from '../../../i18n/utils';

const locale: Locale = 'en';
const serviceKey = 'seo';
const slugMapKey = 'seo';
const { roSlug, enSlug } = { roSlug: slugMap[slugMapKey].ro, enSlug: slugMap[slugMapKey].en };

const service = await getServiceByKey(serviceKey);
const title = service ? localize(service.metaTitle, locale) : 'SEO — Isio';
const description = service ? localize(service.metaDescription, locale) : '';
const serviceLabel = title.split(' — ')[0];
---
<Page title={title} description={description} locale={locale} roSlug={roSlug} enSlug={enSlug} pageType="service" serviceName={serviceLabel}>
  <ServicePageLayout serviceKey={serviceKey} locale={locale} />
</Page>
