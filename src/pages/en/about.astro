---
export const prerender = true;

import Page from '../../layouts/Page.astro';
import { slugMap, localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

const locale: Locale = 'en';
const { roSlug, enSlug } = { roSlug: slugMap.about.ro, enSlug: slugMap.about.en };
---
<Page title="About — Isio" description="Web agency founded by a developer with expertise in accessibility, SEO, and web applications." locale={locale} roSlug={roSlug} enSlug={enSlug}>
  <!-- Hero -->
  <section class="bg-base-950 dot-mesh py-24 relative overflow-hidden">
    <div class="radial-glow absolute inset-0 pointer-events-none" aria-hidden="true"></div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      <span class="section-tag" data-animate>About</span>
      <h1 class="text-4xl sm:text-5xl font-bold font-heading text-white mt-4" data-animate>About Isio</h1>
      <p class="mt-6 text-xl text-base-300 max-w-3xl" data-animate>
        A web agency built on the principle that technology should be accessible, performant, and autonomous.
      </p>
    </div>
  </section>

  <!-- Bio -->
  <section class="bg-base-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="glass-card p-8" data-animate>
          <h2 class="text-2xl font-bold font-heading text-white">Developer & Founder</h2>
          <p class="mt-6 text-base-300 leading-relaxed">
            Isio was founded by a full-stack developer with 7+ years of experience building web products.
            From accessibility marketplaces to autonomous AI agents, every project is approached with the same
            attention to technical detail and user experience.
          </p>
          <p class="mt-4 text-base-300 leading-relaxed">
            Our philosophy: deliver solutions that run independently, with clean code, exceptional performance,
            and accessibility from the very first line of code.
          </p>
        </div>
        <div class="glass-card p-8" data-animate>
          <h2 class="text-2xl font-bold font-heading text-white mb-6">Specializations</h2>
          <div class="grid grid-cols-2 gap-3">
            {[
              'Web Development',
              'Web Apps',
              'Technical SEO',
              'WCAG Accessibility',
              'AI Agents',
              'TypeScript',
              'Astro & React',
              'PostgreSQL',
            ].map((skill) => (
              <div class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-center hover:bg-white/10 hover:border-electric-500/30 transition-all duration-200">
                <span class="text-sm font-semibold text-base-200">{skill}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-base-900 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-animate>
        <span class="section-tag">Principles</span>
        <h2 class="text-3xl font-bold font-heading text-white mt-4">Our values</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="glass-card p-8 text-center" data-animate>
          <div class="gradient-text text-3xl font-bold font-heading mb-3">Performance</div>
          <p class="text-base-300 text-sm leading-relaxed">100/100 Lighthouse scores. Every millisecond matters for conversions and user experience.</p>
        </div>
        <div class="glass-card p-8 text-center" data-animate>
          <div class="gradient-text text-3xl font-bold font-heading mb-3">Accessibility</div>
          <p class="text-base-300 text-sm leading-relaxed">WCAG 2.1 from day one. Everyone deserves equal access to the web, regardless of device or disability.</p>
        </div>
        <div class="glass-card p-8 text-center" data-animate>
          <div class="gradient-text text-3xl font-bold font-heading mb-3">Autonomy</div>
          <p class="text-base-300 text-sm leading-relaxed">Solutions that run themselves. Intelligent automation, not dependence on manual intervention.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-base-950 py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="glass-card p-12 text-center relative overflow-hidden" data-animate>
        <div class="radial-glow absolute inset-0 pointer-events-none opacity-60" aria-hidden="true"></div>
        <div class="relative z-10">
          <h2 class="text-3xl font-bold font-heading text-white">Let's build together</h2>
          <p class="mt-4 text-base-300 max-w-xl mx-auto">Have a project in mind? Schedule a free discovery call and let's see how we can work together.</p>
          <a href={localePath('contact', locale)} class="btn-glow inline-block mt-8">
            Schedule a call
          </a>
        </div>
      </div>
    </div>
  </section>
</Page>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray('[data-animate]').forEach((el) => {
    gsap.from(el as Element, {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: { trigger: el as Element, start: 'top 85%' }
    });
  });
</script>
