---
export const prerender = true;

import Page from '../../layouts/Page.astro';
import { slugMap, localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

const locale: Locale = 'en';
const { roSlug, enSlug } = { roSlug: slugMap.about.ro, enSlug: slugMap.about.en };
---
<Page title="About — Isio" description="Web agency founded by a developer with expertise in accessibility, SEO, and web applications." locale={locale} roSlug={roSlug} enSlug={enSlug}>
  <!-- Hero -->
  <section class="bg-navy-950 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-bold font-heading text-white">About Isio</h1>
      <p class="mt-6 text-xl text-navy-300 max-w-3xl">
        A web agency built on the principle that technology should be accessible, performant, and autonomous.
      </p>
    </div>
  </section>

  <!-- Bio -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <div>
        <h2 class="text-2xl font-bold font-heading text-navy-950">Developer & Founder</h2>
        <p class="mt-6 text-navy-600 leading-relaxed">
          Isio was founded by a full-stack developer with 7+ years of experience building web products.
          From accessibility marketplaces to autonomous AI agents, every project is approached with the same
          attention to technical detail and user experience.
        </p>
        <p class="mt-4 text-navy-600 leading-relaxed">
          Our philosophy: deliver solutions that run independently, with clean code, exceptional performance,
          and accessibility from the very first line of code.
        </p>
      </div>
      <div>
        <h2 class="text-2xl font-bold font-heading text-navy-950">Specializations</h2>
        <div class="mt-6 grid grid-cols-2 gap-4">
          {[
            'Web Development',
            'Web Apps',
            'Technical SEO',
            'WCAG Accessibility',
            'AI Agents',
            'TypeScript',
            'Astro & React',
            'PostgreSQL',
          ].map((skill) => (
            <div class="bg-navy-50 rounded-xl px-4 py-3 text-center">
              <span class="text-sm font-semibold text-navy-700">{skill}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-navy-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-heading text-navy-950 text-center">Our values</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
        <div class="text-center">
          <div class="text-3xl font-bold text-electric-500 font-heading">Performance</div>
          <p class="mt-3 text-navy-600 text-sm">100/100 Lighthouse scores. Every millisecond counts.</p>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-electric-500 font-heading">Accessibility</div>
          <p class="mt-3 text-navy-600 text-sm">WCAG 2.1 from day one. Everyone deserves equal access to the web.</p>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-electric-500 font-heading">Autonomy</div>
          <p class="mt-3 text-navy-600 text-sm">Solutions that run themselves. Automation, not dependency.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 text-center">
    <h2 class="text-3xl font-bold font-heading text-navy-950">Let's build together</h2>
    <p class="mt-4 text-navy-500 max-w-xl mx-auto">Have a project in mind? Schedule a free discovery call.</p>
    <a href={localePath('contact', locale)} class="inline-block mt-8 bg-electric-500 hover:bg-electric-600 text-white px-8 py-4 rounded-full font-semibold transition-colors">
      Schedule a call
    </a>
  </section>
</Page>
