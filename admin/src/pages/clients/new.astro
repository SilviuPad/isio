---
export const prerender = false;

import Layout from '../../components/Layout.astro';
---

<Layout title="Add Client">
  <div class="max-w-2xl">
    <div class="mb-6">
      <a href="/clients" class="text-muted hover:text-gray-900 text-sm transition-colors inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to clients
      </a>
      <h1 class="text-2xl font-bold text-gray-900 mt-2">Add Client</h1>
    </div>

    <div id="error-msg" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"></div>

    <form id="client-form" class="space-y-8">
      <div class="bg-surface border border-border rounded-xl p-6">
        <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Client Information</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="companyName" class="block text-sm font-medium text-gray-700 mb-1.5">
              Company / Person Name <span class="text-red-500">*</span>
            </label>
            <input type="text" id="companyName" name="companyName" required
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
          </div>
          <div>
            <label for="contactPerson" class="block text-sm font-medium text-gray-700 mb-1.5">Contact Person</label>
            <input type="text" id="contactPerson" name="contactPerson"
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
              Email <span class="text-red-500">*</span>
            </label>
            <input type="email" id="email" name="email" required
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone</label>
            <input type="tel" id="phone" name="phone"
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
          </div>
          <div>
            <label for="cui" class="block text-sm font-medium text-gray-700 mb-1.5">CUI / Fiscal Code</label>
            <input type="text" id="cui" name="cui"
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
          </div>
          <div>
            <label for="iban" class="block text-sm font-medium text-gray-700 mb-1.5">IBAN / Bank Details</label>
            <input type="text" id="iban" name="iban"
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
          </div>
          <div class="md:col-span-2">
            <label for="address" class="block text-sm font-medium text-gray-700 mb-1.5">Address</label>
            <textarea id="address" name="address" rows="2"
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"></textarea>
          </div>
          <div class="md:col-span-2">
            <label for="notes" class="block text-sm font-medium text-gray-700 mb-1.5">Notes</label>
            <textarea id="notes" name="notes" rows="3"
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"></textarea>
          </div>
        </div>
      </div>

      <div class="bg-surface border border-border rounded-xl p-6">
        <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Project (optional)</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="projectName" class="block text-sm font-medium text-gray-700 mb-1.5">Project Name</label>
            <input type="text" id="projectName" name="projectName"
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
          </div>
          <div>
            <label for="projectDueDate" class="block text-sm font-medium text-gray-700 mb-1.5">Due Date</label>
            <input type="date" id="projectDueDate" name="projectDueDate"
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
          </div>
          <div>
            <label for="projectStatus" class="block text-sm font-medium text-gray-700 mb-1.5">Status</label>
            <select id="projectStatus" name="projectStatus"
              class="border border-border rounded-lg px-3.5 py-2.5 w-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent bg-white">
              <option value="not_started">Not started</option>
              <option value="in_progress">In progress</option>
              <option value="review">Review</option>
              <option value="blocked">Blocked</option>
              <option value="done">Done</option>
            </select>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" id="submit-btn"
          class="bg-brand-600 text-white rounded-lg px-5 py-2.5 text-sm font-medium hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 disabled:opacity-50 transition-colors shadow-sm">
          Save Client
        </button>
        <a href="/clients" class="text-muted hover:text-gray-900 text-sm font-medium transition-colors">Cancel</a>
      </div>
    </form>
  </div>
</Layout>

<script is:inline>
  var form = document.getElementById('client-form');
  var errorMsg = document.getElementById('error-msg');
  var submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    errorMsg.textContent = '';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving...';

    var data = new FormData(form);
    var body = {};
    data.forEach(function(value, key) {
      if (value !== '') body[key] = value;
    });

    try {
      var res = await fetch('/api/clients', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.status === 201) {
        window.location.href = '/clients';
      } else {
        var result = await res.json();
        errorMsg.textContent = result.error || 'Failed to save client.';
        errorMsg.classList.remove('hidden');
      }
    } catch (err) {
      errorMsg.textContent = 'Network error. Please try again.';
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Save Client';
    }
  });
</script>
