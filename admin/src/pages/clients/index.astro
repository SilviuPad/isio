---
export const prerender = false;

import Layout from '../../components/Layout.astro';
import type { Client } from '../../lib/schema';
import { getDb } from '../../lib/db';
import { clients as clientsTable } from '../../lib/schema';

const db = getDb(Astro.locals.runtime.env.DB);
const allClients: Client[] = await db.select().from(clientsTable).all();

const statusBadge: Record<string, string> = {
  not_started: 'bg-gray-100 text-gray-600',
  in_progress: 'bg-blue-50 text-blue-700',
  review: 'bg-amber-50 text-amber-700',
  blocked: 'bg-red-50 text-red-700',
  done: 'bg-emerald-50 text-emerald-700',
};

const statusDot: Record<string, string> = {
  not_started: 'bg-gray-400',
  in_progress: 'bg-blue-500',
  review: 'bg-amber-500',
  blocked: 'bg-red-500',
  done: 'bg-emerald-500',
};

const statusLabel: Record<string, string> = {
  not_started: 'Not started',
  in_progress: 'In progress',
  review: 'Review',
  blocked: 'Blocked',
  done: 'Done',
};
---

<Layout title="Clients">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Clients</h1>
        <p class="text-muted text-sm mt-0.5">{allClients.length} total</p>
      </div>
      <a href="/clients/new" class="inline-flex items-center gap-2 bg-brand-600 text-white rounded-lg px-4 py-2.5 text-sm font-medium hover:bg-brand-700 transition-colors shadow-sm">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Add Client
      </a>
    </div>

    {allClients.length === 0 ? (
      <div class="bg-surface border border-border rounded-xl p-16 text-center">
        <div class="w-14 h-14 rounded-xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <p class="text-gray-600 font-medium mb-1">No clients yet</p>
        <p class="text-muted text-sm mb-4">Get started by adding your first client.</p>
        <a href="/clients/new" class="inline-flex items-center gap-2 text-brand-600 hover:text-brand-700 font-medium text-sm">
          Add your first client &rarr;
        </a>
      </div>
    ) : (
      <div class="bg-surface border border-border rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left px-5 py-3 text-xs font-medium text-muted uppercase tracking-wider">Company / Name</th>
              <th class="text-left px-5 py-3 text-xs font-medium text-muted uppercase tracking-wider">Contact</th>
              <th class="text-left px-5 py-3 text-xs font-medium text-muted uppercase tracking-wider">Email</th>
              <th class="text-left px-5 py-3 text-xs font-medium text-muted uppercase tracking-wider">Project</th>
              <th class="text-left px-5 py-3 text-xs font-medium text-muted uppercase tracking-wider">Status</th>
              <th class="text-right px-5 py-3 text-xs font-medium text-muted uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border-light">
            {allClients.map(client => (
              <tr class="hover:bg-surface-hover transition-colors group">
                <td class="px-5 py-3.5">
                  <a href={`/clients/${client.id}`} class="font-medium text-gray-900 hover:text-brand-600 transition-colors">
                    {client.companyName}
                  </a>
                </td>
                <td class="px-5 py-3.5 text-muted">{client.contactPerson || '\u2014'}</td>
                <td class="px-5 py-3.5 text-muted">{client.email}</td>
                <td class="px-5 py-3.5 text-muted">{client.projectName || '\u2014'}</td>
                <td class="px-5 py-3.5">
                  {client.projectName ? (
                    <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium ${statusBadge[client.projectStatus ?? 'not_started']}`}>
                      <span class={`w-1.5 h-1.5 rounded-full ${statusDot[client.projectStatus ?? 'not_started']}`}></span>
                      {statusLabel[client.projectStatus ?? 'not_started']}
                    </span>
                  ) : (
                    <span class="text-gray-300">\u2014</span>
                  )}
                </td>
                <td class="px-5 py-3.5 text-right">
                  <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                    <a href={`/clients/${client.id}`} class="px-2.5 py-1 text-xs font-medium text-muted hover:text-brand-600 hover:bg-brand-50 rounded-md transition-colors">Edit</a>
                    <button
                      class="px-2.5 py-1 text-xs font-medium text-muted hover:text-red-600 hover:bg-red-50 rounded-md transition-colors delete-btn"
                      data-id={client.id}
                      data-name={client.companyName}
                    >
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</Layout>

<script is:inline>
  document.querySelectorAll('.delete-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var id = btn.getAttribute('data-id');
      var name = btn.getAttribute('data-name');
      if (!confirm('Delete "' + name + '"? This cannot be undone.')) return;
      try {
        var res = await fetch('/api/clients/' + id, { method: 'DELETE' });
        if (res.ok) {
          window.location.reload();
        } else {
          alert('Failed to delete client.');
        }
      } catch (e) {
        alert('Network error. Please try again.');
      }
    });
  });
</script>
