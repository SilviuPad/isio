---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

function isActive(path: string): boolean {
  return currentPath === path || currentPath.startsWith(path + '/');
}
---

<nav class="bg-white border-b border-gray-200 px-6 py-3">
  <div class="max-w-6xl mx-auto flex items-center justify-between">
    <span class="font-bold text-gray-900">Isio Admin</span>

    <div class="flex items-center gap-6">
      <a
        href="/dashboard"
        class={`font-medium ${isActive('/dashboard') ? 'text-blue-600' : 'text-gray-600 hover:text-gray-900'}`}
      >
        Dashboard
      </a>
      <a
        href="/clients"
        class={`font-medium ${isActive('/clients') ? 'text-blue-600' : 'text-gray-600 hover:text-gray-900'}`}
      >
        Clients
      </a>
      <a
        href="/generate"
        class={`font-medium ${isActive('/generate') ? 'text-blue-600' : 'text-gray-600 hover:text-gray-900'}`}
      >
        Generate Document
      </a>
    </div>

    <button
      id="logout-btn"
      class="text-gray-500 hover:text-red-600 font-medium text-sm"
    >
      Logout
    </button>
  </div>
</nav>

<script is:inline>
  document.getElementById('logout-btn').addEventListener('click', async () => {
    try {
      await fetch('/api/auth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'logout' }),
      });
    } finally {
      window.location.href = '/';
    }
  });
</script>
